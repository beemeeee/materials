    .filter(g=>!q||g.t.toLowerCase().includes(q)||g.ko.includes(q)||g.d.includes(q))
    .map((g,i)=>{
      const ex=(locked(g.sp)&&!state.over["g"+i])
        ? '<span class="gx-lock" data-g="'+i+'">🔒 예시는 Ch.'+g.sp+' 이후 추천 — 탭하면 보기</span>'
