function updateAsm(){
  const b=state.builder;
  document.getElementById("basm").textContent=["p","e","t","a","l"].map(k=>b[k]||"").filter(Boolean).join(" ")||"(칸을 채우면 완성 단락이 여기 나타나요)";
}
function renderDrafts(){
  const w=document.getElementById("bdrafts");
  if(!state.drafts.length){ w.innerHTML='<div class="empty">아직 저장된 드래프트가 없어요.</div>'; return; }
  w.innerHTML=state.drafts.map((d,i)=>'<div class="draft"><div class="dh"><span>'+esc(d.when)+' · '+esc(PNP2.LENSES[d.lens]?PNP2.LENSES[d.lens].n:"")+' 렌즈</span><button class="dx" data-i="'+i+'">삭제</button></div>'+esc(d.text)+'</div>').join("");
  w.querySelectorAll(".dx").forEach(b=>{ b.onclick=()=>{ state.drafts.splice(parseInt(b.dataset.i),1); save(); renderDrafts(); }; });
