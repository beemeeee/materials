      return '<div class="grow"><b>'+esc(g.t)+'</b> <span class="gk">'+esc(g.ko)+'</span> — '+esc(g.d)+'<br>'+ex+'</div>'; }).join("")||'<div class="empty">결과 없음</div>';
  document.getElementById("gloss").querySelectorAll(".gx-lock").forEach(el=>{ el.onclick=()=>{ state.over["g"+el.dataset.g]=true; save(); renderGloss(document.getElementById("gsearch").value.trim()); }; });
}
document.getElementById("gsearch").oninput=e=>renderGloss(e.target.value.trim());
