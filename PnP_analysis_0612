/* ---------- builder ---------- */
const PETAL_FIELDS=[["p","P — Point","렌즈의 주어로 시작하는 주장 한 문장"],["e","E — Evidence","짧은 인용 한두 개 (한두 단어~한 구절)"],["t","T — Technique","기법 이름 명시 — 아래 칩을 탭"],["a","A — Analysis","가장 길게: 효과·이유·대안 비교"],["l","L — Link","질문어로 한 문장 귀환"]];
function renderBuilder(){
  const lw=document.getElementById("blens"); lw.innerHTML="";
  Object.entries(PNP2.LENSES).forEach(([k,L])=>{ const b=document.createElement("button");
    b.textContent=L.e+" "+L.n; if(state.builder.lens===k)b.classList.add("on");
    b.onclick=()=>{ state.builder.lens=k; save(); renderBuilder(); }; lw.appendChild(b); });
  const L=PNP2.LENSES[state.builder.lens];
  document.getElementById("bstems").innerHTML=
    '<div class="lh">'+L.e+' '+esc(L.n)+' 렌즈의 스템 — 탭하면 P칸에 삽입</div>'+
    L.st.map(s=>'<div class="stem" data-s="'+esc(s)+'">'+esc(s)+'</div>').join("")+
    '<div class="lh">기법 칩 — 탭하면 T칸에 삽입</div><div class="tchips">'+
    L.tech.map(t=>'<span class="tchip" data-t="'+esc(t)+'" style="cursor:pointer">'+esc(t)+'</span>').join("")+'</div>';
  document.getElementById("bstems").querySelectorAll(".stem").forEach(s=>{ s.onclick=()=>{ state.builder.p=(state.builder.p?state.builder.p+" ":"")+s.dataset.s; save(); renderBuilder(); flash("P칸에 삽입"); }; });
  document.getElementById("bstems").querySelectorAll(".tchip").forEach(c=>{ c.onclick=()=>{ state.builder.t=(state.builder.t?state.builder.t+", ":"")+c.dataset.t; save(); renderBuilder(); flash("T칸에 삽입"); }; });
  const f=document.getElementById("bform");
  f.innerHTML=PETAL_FIELDS.map(([k,n,h])=>'<label>'+n+' <span>· '+h+'</span></label><textarea data-k="'+k+'">'+esc(state.builder[k]||"")+'</textarea>').join("");
  f.querySelectorAll("textarea").forEach(t=>{ t.oninput=()=>{ state.builder[t.dataset.k]=t.value; updateAsm(); save(); }; });
