  nb.onclick=()=>{ vSec=String(nextSec()); vQuiz=null; buildVDeck(); renderVScope(); renderVocab(); flash("§"+(nextSec()+1)+" 구간 단어만 보여요"); };
  s.appendChild(nb);
}
function buildVDeck(){ vDeck=shuffle(vFiltered()).sort((a,b)=>(state.boxes[a.w]||0)-(state.boxes[b.w]||0)); vIdx=0; vFlip=false; }
function renderVocab(){
  document.getElementById("vprog").textContent="외운 단어 "+knownCount()+" / "+WORDS.length;
  document.querySelectorAll("[data-vm]").forEach(b=>{ b.style.background=(b.dataset.vm===vMode)?"var(--gilt-pale)":"#fff"; b.style.fontWeight=(b.dataset.vm===vMode)?"700":"400"; b.style.color=(b.dataset.vm===vMode)?"var(--ink)":"var(--soft)"; });
  const area=document.getElementById("varea");
  if(vMode==="cards") renderVCard(area);
  else if(vMode==="list") renderVList(area);
  else renderVQuiz(area);
}
function renderVCard(area){
  if(!vDeck.length){ area.innerHTML='<div class="empty">'+(vScope==="unknown"?"🎉 안 외운 단어가 없어요!":"조건에 맞는 단어가 없어요.")+'</div>'; return; }
  if(vIdx>=vDeck.length)vIdx=0;
  const w=vDeck[vIdx], box=state.boxes[w.w]||0;
  area.innerHTML=
    '<div class="fcard" id="fc" role="button" tabindex="0">'+
    '<div class="tag">Tier '+w.tier+(w.tier==="A"?" · 소설 어휘":" · 분석 어휘")+'</div>'+
    '<div class="box">'+"●".repeat(box)+"○".repeat(3-box)+'</div>'+
    (vFlip?'<div class="def">'+esc(w.en)+'</div><div class="kr">'+esc(w.ko)+'</div>'
          :'<div class="word">'+esc(w.w)+'</div><div class="pos">'+esc(w.pos)+'</div>')+
    '<div class="hint">'+(vFlip?"탭 → 앞면":"탭 → 뜻 보기")+'</div></div>'+
    '<div class="fbtns"><button class="b-again">다시 볼래요</button><button class="b-know">알아요!</button></div>'+
    '<div class="fmeta"><span>'+(vIdx+1)+' / '+vDeck.length+'</span><span>●● 이상 = 외운 것</span></div>';
  const fc=document.getElementById("fc"); const flip=()=>{ vFlip=!vFlip; renderVCard(area); };
  fc.onclick=flip; fc.onkeydown=e=>{ if(e.key==="Enter"||e.key===" "){e.preventDefault();flip();} };
  area.querySelector(".b-again").onclick=()=>{ state.boxes[w.w]=0; save(); vNext(area); };
  area.querySelector(".b-know").onclick=()=>{ state.boxes[w.w]=Math.min(3,(state.boxes[w.w]||0)+1); save(); vNext(area); };
}
function vNext(area){ vIdx++; vFlip=false; if(vScope==="unknown"){ buildVDeck(); } if(vIdx>=vDeck.length)vIdx=0; renderVocab(); }
function renderVList(area){
  const ws=vFiltered();
  if(!ws.length){ area.innerHTML='<div class="empty">결과가 없어요.</div>'; return; }
  area.innerHTML=ws.map(w=>'<div class="vrow">'+((state.boxes[w.w]||0)>=2?'<span class="st">✓ 외움</span>':'')+
    '<b>'+esc(w.w)+'</b> <i style="color:var(--soft);font-size:13px">'+esc(w.pos)+' · '+w.tier+'</i><br>'+
    esc(w.en)+' — <span style="color:var(--wg-deep)">'+esc(w.ko)+'</span></div>').join("");
}
function renderVQuiz(area){
  const ws=vFiltered();
  if(ws.length<4){ area.innerHTML='<div class="empty">퀴즈엔 단어가 4개 이상 필요해요.</div>'; return; }
  if(!vQuiz){ vQuiz={qs:shuffle(ws).slice(0,10),i:0,score:0,lock:false}; }
  if(vQuiz.i>=vQuiz.qs.length){
    area.innerHTML='<div class="empty" style="font-size:17px">🎉 '+vQuiz.qs.length+'문제 중 <b>'+vQuiz.score+'개</b> 정답!<br><br><button class="solid" id="rq">다시 풀기 ↺</button></div>';
    document.getElementById("rq").onclick=()=>{ vQuiz=null; renderVQuiz(area); }; return;
  }
  const q=vQuiz.qs[vQuiz.i];
  const opts=shuffle([q.ko,...shuffle(WORDS.filter(x=>x.w!==q.w)).slice(0,3).map(x=>x.ko)]);
  area.innerHTML='<div class="quizq"><div class="note">'+(vQuiz.i+1)+' / '+vQuiz.qs.length+'</div>'+
    '<div class="qw">'+esc(q.w)+' <span style="font-size:14px;color:var(--soft);font-style:italic">('+esc(q.pos)+')</span></div>'+
    opts.map(o=>'<button data-ok="'+(o===q.ko)+'">'+esc(o)+'</button>').join("")+'</div>';
  area.querySelectorAll(".quizq button").forEach(b=>{ b.onclick=()=>{
    if(vQuiz.lock)return; vQuiz.lock=true;
    const ok=b.dataset.ok==="true";
    if(ok){ b.classList.add("right"); vQuiz.score++; state.boxes[q.w]=Math.min(3,(state.boxes[q.w]||0)+1); }
    else{ b.classList.add("wrong"); area.querySelector('button[data-ok="true"]').classList.add("right"); state.boxes[q.w]=0; }
    save(); setTimeout(()=>{ vQuiz.i++; vQuiz.lock=false; renderVQuiz(area); }, ok?650:1400);
  }; });
}
document.querySelectorAll("[data-vm]").forEach(b=>{ b.onclick=()=>{ vMode=b.dataset.vm; vQuiz=null; if(vMode==="cards")buildVDeck(); renderVocab(); }; });
document.getElementById("vshuffle").onclick=()=>{ buildVDeck(); vQuiz=null; renderVocab(); };
document.getElementById("vsearch").oninput=e=>{ vQuery=e.target.value.trim(); vQuiz=null; if(vMode==="cards")buildVDeck(); renderVocab(); };

