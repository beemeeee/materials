<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>어휘 트레이너 — Animal Farm 전권</title>
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&family=Noto+Sans+KR:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --bg-main:#e8e3d4; --bg-paper:#fcfaf3; --bg-paper-light:#ffffff;
  --bg-dark:#6e3a2a; --on-dark-bg:#f8f0db;
  --accent:#d4a04c; --accent-light:#e3b86e; --accent-deep:#a07530; --accent-gold:#f4cd80;
  --ink:#3a2818; --ink-soft:#5e4530; --muted:#a08858;
  --border:#d9c599; --border-soft:#e8d8b0;
  --ok:#6a8a4a; --ok-soft:#85a565; --near:#c98a2c; --miss:#b85838; --miss-soft:#d8a088;
  --fen:'Source Serif 4','Noto Sans KR',Georgia,serif;
  --fko:'Noto Sans KR',sans-serif; --ftitle:'Playfair Display','Noto Sans KR',serif;
}
body.dark{
  --bg-main:#1f1810; --bg-paper:#2a2014; --bg-paper-light:#352a1c;
  --bg-dark:#1a130c; --on-dark-bg:#e8d8b0;
  --accent:#e8b85c; --accent-light:#f5cd80; --accent-deep:#b8862c; --accent-gold:#f5cd80;
  --ink:#f0e3c8; --ink-soft:#d4c4a0; --muted:#a89878;
  --border:#4a3c28; --border-soft:#3a2e1f;
  --ok:#b8d895; --ok-soft:#a0c878; --near:#e3b86e; --miss:#e89a78; --miss-soft:#f0b89a;
}
*{box-sizing:border-box} html,body{margin:0;padding:0}
body{background:var(--bg-main);color:var(--ink);font-family:var(--fko);line-height:1.6;-webkit-font-smoothing:antialiased;
  background-image:radial-gradient(circle at 12% 8%, rgba(212,160,76,.05), transparent 40%),radial-gradient(circle at 88% 92%, rgba(110,58,42,.05), transparent 40%);}
.wrap{max-width:680px;margin:0 auto;padding:24px 18px 80px}
header{background:var(--bg-dark);color:var(--on-dark-bg);border-radius:14px;padding:20px 22px;margin-bottom:16px;position:relative;overflow:hidden;box-shadow:0 6px 24px rgba(58,40,24,.18)}
header::after{content:"";position:absolute;inset:0;background:repeating-linear-gradient(135deg,rgba(255,255,255,.03) 0 2px,transparent 2px 7px);pointer-events:none}
.kicker{font-family:var(--fen);font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent-gold);opacity:.9}
header h1{font-family:var(--ftitle);font-size:1.55rem;margin:.22em 0 .12em;font-weight:700}
header p{margin:0;font-size:.87rem;opacity:.82}
.theme-tog{position:absolute;top:14px;right:14px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:var(--on-dark-bg);border-radius:20px;padding:5px 12px;font-size:.76rem;cursor:pointer;font-family:var(--fko);z-index:1}
.home-btn{position:absolute;top:14px;right:118px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:var(--on-dark-bg);border-radius:20px;padding:5px 12px;font-size:.76rem;cursor:pointer;font-family:var(--fko);z-index:1}

/* chapter grid */
.chgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px}
.chcard{background:var(--bg-paper);border:1px solid var(--border);border-radius:12px;padding:14px 14px 12px;cursor:pointer;transition:.18s;box-shadow:0 2px 8px rgba(58,40,24,.05)}
.chcard:hover{border-color:var(--accent);transform:translateY(-2px)}
.chcard .t{font-family:var(--fen);font-weight:700;font-size:1.02rem}
.chcard .n{font-size:.76rem;color:var(--muted);margin:2px 0 8px}
.chbar{height:6px;border-radius:3px;background:var(--border-soft);overflow:hidden;display:flex}
.chbar i{height:100%}
.chbar .b-m{background:var(--ok)} .chbar .b-l{background:var(--accent-light)}
.chcard .due{font-size:.72rem;margin-top:6px;color:var(--accent-deep)}
.chcard .due.zero{color:var(--muted)}
.legend{font-size:.74rem;color:var(--muted);margin:12px 2px 0}
.legend i{display:inline-block;width:10px;height:10px;border-radius:3px;vertical-align:-1px;margin:0 3px 0 10px}
.legend .b-m{background:var(--ok)} .legend .b-l{background:var(--accent-light)} .legend .b-0{background:var(--border-soft)}

/* progress + cards (shared with preflight) */
.prog{display:flex;gap:4px;margin:16px 2px 18px}
.prog i{flex:1;height:5px;border-radius:3px;background:var(--border-soft);transition:.3s}
.prog i.done{background:var(--ok)} .prog i.cur{background:var(--accent)}
.stage-label{font-family:var(--fen);font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:4px;display:flex;align-items:center;gap:8px}
.stage-label .pace{margin-left:auto;color:var(--muted);letter-spacing:.04em;text-transform:none;font-family:var(--fko)}
.card{background:var(--bg-paper);border:1px solid var(--border);border-radius:14px;padding:20px 20px 18px;box-shadow:0 3px 14px rgba(58,40,24,.07);animation:rise .35s cubic-bezier(.2,.7,.3,1)}
@keyframes rise{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.badge{display:inline-block;font-size:.68rem;font-family:var(--fen);letter-spacing:.1em;text-transform:uppercase;padding:2px 9px;border-radius:20px;margin-bottom:10px}
.badge.new{color:var(--accent-deep);background:rgba(212,160,76,.16)}
.badge.rev{color:var(--ok);background:rgba(106,138,74,.14)}
.ctx{font-family:var(--fen);font-size:1.04rem;line-height:1.75;color:var(--ink-soft);background:var(--bg-paper-light);border-left:3px solid var(--accent);padding:13px 15px;border-radius:0 8px 8px 0;margin-bottom:6px}
.ctx .target{font-weight:700;color:var(--ink);background:linear-gradient(transparent 58%, var(--accent-light) 58%);padding:0 2px;border-radius:2px}
.src{font-size:.72rem;color:var(--muted);font-family:var(--fen);text-align:right;margin:4px 2px 14px}
.q{font-size:.94rem;margin:2px 0 10px}
.q b{color:var(--accent-deep);font-family:var(--fen)}
input.guess{width:100%;font-family:var(--fko);font-size:1rem;color:var(--ink);background:var(--bg-paper-light);border:1.5px solid var(--border);border-radius:9px;padding:11px 13px;outline:none;transition:border .2s}
input.guess:focus{border-color:var(--accent)}
.conf{display:flex;gap:7px;margin:12px 0 4px}
.conf button{flex:1;font-size:.8rem;color:var(--ink-soft);background:var(--bg-paper-light);border:1.5px solid var(--border);border-radius:9px;padding:8px 4px;cursor:pointer;transition:.18s;font-family:var(--fko)}
.conf button:hover{border-color:var(--accent)}
.conf button.on{background:var(--accent);color:#fff;border-color:var(--accent);font-weight:600}
body.dark .conf button.on{color:#1f1810}
.row{display:flex;gap:9px;margin-top:14px}
.btn{flex:1;font-family:var(--fko);font-size:.93rem;font-weight:600;cursor:pointer;border-radius:10px;padding:12px;border:none;transition:.18s}
.btn-main{background:var(--accent);color:#fff}
body.dark .btn-main{color:#1f1810}
.btn-main:hover{background:var(--accent-deep)}
.btn-main:disabled{opacity:.45;cursor:not-allowed}
.btn-ghost{background:transparent;color:var(--muted);border:1.5px solid var(--border);flex:0 0 auto;padding:12px 16px}
.btn-ghost:hover{color:var(--ink);border-color:var(--muted)}
.word-head{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;border-bottom:1px dashed var(--border);padding-bottom:10px;margin-bottom:11px}
.word-head .w{font-family:var(--fen);font-size:1.45rem;font-weight:700}
.word-head .pos{font-style:italic;color:var(--muted);font-family:var(--fen);font-size:.9rem}
.word-head .pron{color:var(--accent-deep);font-family:var(--fen);font-size:.9rem}
.spk{background:none;border:none;cursor:pointer;font-size:1rem;opacity:.7}.spk:hover{opacity:1}
.mean{font-size:1.06rem;margin-bottom:4px}
.lemma{font-size:.86rem;color:var(--accent-deep);font-family:var(--fen);margin:2px 0 4px;padding:5px 10px;background:rgba(212,160,76,.1);border-radius:6px;display:inline-block}
.lemma b{font-size:.95rem}
.note{font-size:.86rem;color:var(--ink-soft);line-height:1.65;margin-top:10px;background:var(--bg-paper-light);border-radius:8px;padding:10px 13px;border:1px solid var(--border-soft)}
.contrast{display:flex;gap:10px;margin:13px 0 4px}
.contrast div{flex:1;border-radius:9px;padding:9px 12px;font-size:.88rem}
.contrast .mine{background:var(--bg-main);border:1px solid var(--border)}
.contrast .real{background:rgba(106,138,74,.1);border:1px solid var(--ok-soft)}
.contrast .lbl{font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:3px;font-family:var(--fen)}
.contrast .mine .val{color:var(--ink-soft);font-style:italic}
.contrast .real .val{font-weight:500}
.grade-q{font-size:.88rem;color:var(--ink-soft);margin:15px 0 8px;text-align:center}
.grade{display:flex;gap:9px}
.grade button{flex:1;font-size:.88rem;font-weight:600;cursor:pointer;border-radius:10px;padding:11px 6px;border:1.5px solid;transition:.18s;font-family:var(--fko);background:transparent}
.grade .g-ok{color:var(--ok);border-color:var(--ok-soft)} .grade .g-ok:hover{background:rgba(106,138,74,.12)}
.grade .g-near{color:var(--near);border-color:var(--near)} .grade .g-near:hover{background:rgba(201,138,44,.12)}
.grade .g-miss{color:var(--miss);border-color:var(--miss-soft)} .grade .g-miss:hover{background:rgba(184,88,56,.12)}
.retr-blank{display:inline-block;min-width:90px;border-bottom:2px solid var(--accent);text-align:center;font-weight:700;color:var(--accent-deep)}
.feedback{font-size:.88rem;margin-top:12px;padding:10px 13px;border-radius:8px;animation:rise .3s}
.feedback.right{background:rgba(106,138,74,.12);color:var(--ok);border:1px solid var(--ok-soft)}
.feedback.wrong{background:rgba(184,88,56,.1);color:var(--miss);border:1px solid var(--miss-soft)}
.feedback b{font-family:var(--fen)}
.summary{text-align:center}
.summary h2{font-family:var(--ftitle);font-size:1.4rem;margin:.2em 0 .4em}
.stat-row{display:flex;gap:10px;margin:16px 0}
.stat{flex:1;background:var(--bg-paper-light);border:1px solid var(--border);border-radius:12px;padding:14px 8px}
.stat .n{font-family:var(--fen);font-size:1.8rem;font-weight:700;line-height:1}
.stat .l{font-size:.76rem;color:var(--muted);margin-top:4px}
.stat.s-ok .n{color:var(--ok)} .stat.s-near .n{color:var(--near)} .stat.s-miss .n{color:var(--miss)}
.boxviz{display:flex;gap:6px;margin:14px 0 4px;align-items:flex-end;height:64px}
.boxviz .bv{flex:1;display:flex;flex-direction:column;justify-content:flex-end;gap:4px}
.boxviz .bar{background:var(--accent-light);border-radius:4px 4px 0 0;min-height:3px;transition:.4s}
.boxviz .bv:last-child .bar{background:var(--ok)}
.boxviz .bl{font-size:.66rem;color:var(--muted);text-align:center}
.note-foot{font-size:.8rem;color:var(--muted);margin-top:20px;line-height:1.6}
</style>
</head>
