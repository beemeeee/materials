, "pron": "/frəm pɪɡ tə mæn/", "mean": "돼지에서 인간으로 ... 인간에서 돼지로", "ctx": "Twelve voices were shouting in anger, and they were all alike. No question, now, what had happened to the faces of the pigs. The creatures outside looked ⟦from⟧ pig to man, and from man to pig, and from pig to man again; but already it was impossible to say which was which.", "marked": true, "note": "동물들의 시선이 두 대상 사이를 오가는 움직임을 그린다. looked from pig to man, and from man to pig, and from pig to man again(돼지에서 인간으로, 인간에서 돼지로, 다시 돼지에서 인간으로 보았다)에서, 시선이 세 번 왕복한다. 차이를 찾으려 거듭 둘을 견주는 그 다급한 시선이, 끝내 아무 차이도 찾지 못한다. 'again(다시)'으로 끝나는 이 순환이, 두 대상이 완전히 포개졌음을—더 견줄 것이 없음을—몸짓으로 보여 준다.", "sid": "c10s055"}, {"word": "which was which", "pos": "phr.", "pron": "/wɪtʃ wəz wɪtʃ/", "mean": "어느 쪽이 어느 쪽인지", "ctx": "Twelve voices were shouting in anger, and they were all alike. No question, now, what had happened to the faces of the pigs. The creatures outside looked from pig to man, and from man to pig, and from pig to man again; but already it was impossible to say ⟦which was which⟧.", "marked": true, "note": "둘 중 무엇이 무엇인지 가림을 뜻하는 관용 표현이다. it was impossible to say which was which(어느 쪽이 어느 쪽인지 말하는 것은 불가능했다)에서, 'which was which(어느 쪽이 어느 쪽인지)'라는 단순한 표현이 작품 전체의 결론을 담는다. 돼지와 인간—혁명가와 압제자—을 더 이상 구별할 수 없다. 'impossible(불가능)'이라는 단정이, 그 구별 불가가 일시적 착각이 아니라 완성된 사실임을 못 박는다. 혁명은 자신이 타도한 것과 똑같아졌다.", "sid": "c10s055"}]};
const SRC_BASE = "George Orwell, Animal Farm";
const SESSION_SIZE = 45;   // 한 세션 카드 수 — 이 숫자만 바꾸면 조절됩니다
const INTERVALS = [0,1,2,4,8];      // box → due offset (sessions)
const MAXBOX = 4;
const LS_KEY = 'afVocabTrainer.v1';

/* ── persistent state ── */
let S = load();
function load(){ try{return JSON.parse(localStorage.getItem(LS_KEY))||{};}catch(e){return{};} }
function save(){ try{localStorage.setItem(LS_KEY, JSON.stringify(S));}catch(e){} }
function chState(ch){
  if(!S[ch]) S[ch] = {sess:0, words:{}};
  return S[ch];
}
function wState(ch, word){
  const c = chState(ch);
  if(!c.words[word]) c.words[word] = {box:-1, due:0};   // box -1 = unseen
  return c.words[word];
}

const app = document.getElementById('app');
const hsub = document.getElementById('hsub');
const homeBtn = document.getElementById('homeBtn');
function speak(w){ try{const u=new SpeechSynthesisUtterance(w);u.lang='en-GB';u.rate=.9;speechSynthesis.speak(u);}catch(e){} }
function hl(ctx){ return ctx.replace(/⟦(.+?)⟧/g,'<span class="target">$1</span>'); }
function blankCtx(ctx){ return ctx.replace(/⟦(.+?)⟧/g,'<span class="retr-blank">______</span>'); }
function norm(s){ return (s||"").trim().toLowerCase().replace(/[^a-z]/g,''); }
function esc(s){ return s.replace(/"/g,'&quot;'); }

/* ════════ HOME: chapter grid ════════ */
function goHome(){
  homeBtn.style.display='none';
  hsub.textContent = '챕터를 고르면 한 세션(≈18개)씩 진행됩니다. 새 단어는 추측부터, 복습 단어는 인출부터.';
  let html = '<div class="chgrid">';
  for(const ch of Object.keys(DECK).sort((a,b)=>a-b)){
    const deck = DECK[ch], c = chState(ch);
    let mastered=0, learning=0, due=0, unseen=0;
    for(const e of deck){
      const w = c.words[e.word];
      if(!w || w.box<0){ unseen++; continue; }
      if(w.box>=3) mastered++; else learning++;
      if(w.due<=c.sess) due++;
    }
    const total=deck.length;
    const pm=(mastered/total*100).toFixed(1), pl=(learning/total*100).toFixed(1);
    const dueTxt = (due+unseen>0)? `복습 ${due} · 새 단어 ${unseen}` : '오늘 할 것 없음 ✓';
    html += `<div class="chcard" onclick="startSession('${ch}')">
      <div class="t">Chapter ${ch}</div>
      <div class="n">${total} 단어 · ${c.sess} 세션</div>
      <div class="chbar"><i class="b-m" style="width:${pm}%"></i><i class="b-l" style="width:${pl}%"></i></div>
      <div class="due ${due+unseen?'':'zero'}">${dueTxt}</div>
    </div>`;
  }
  html += '</div><div class="legend">진행도: <i class="b-m"></i>안착(box 3+) <i class="b-l"></i>학습 중 <i class="b-0"></i>미시작</div>';
  app.innerHTML = html;
}

/* ════════ SESSION ════════ */
let CH, QUEUE, qi, sub, conf, curGuess, sessLog;

function startSession(ch){
  CH = ch;
  const c = chState(ch), deck = DECK[ch];
  // 1) due reviews (낮은 box·이른 due 우선)  2) new words 로 채움
  const due = deck.filter(e=>{const w=c.words[e.word]; return w && w.box>=0 && w.due<=c.sess;})
                  .sort((a,b)=>(c.words[a.word].box-c.words[b.word].box)||(c.words[a.word].due-c.words[b.word].due));
  const fresh = deck.filter(e=>{const w=c.words[e.word]; return !w || w.box<0;});
  QUEUE = due.slice(0,SESSION_SIZE);
  if(QUEUE.length<SESSION_SIZE) QUEUE = QUEUE.concat(fresh.slice(0, SESSION_SIZE-QUEUE.length));
  // 교차: 섞기
  for(let k=QUEUE.length-1;k>0;k--){const j=Math.floor(Math.random()*(k+1));[QUEUE[k],QUEUE[j]]=[QUEUE[j],QUEUE[k]];}
  if(!QUEUE.length){ alert('이 챕터는 오늘 복습할 것이 없습니다. 내일 다시 오세요 — 그 간격이 학습입니다.'); return; }
  qi=0; sessLog={ok:0,near:0,miss:0,over:[]};
  homeBtn.style.display='inline-block';
  hsub.textContent = `Chapter ${ch} — 세션 ${chState(ch).sess+1}`;
  renderCard();
}
function renderProg(){
  let h='<div class="prog">';
  for(let k=0;k<QUEUE.length;k++) h+=`<i class="${k<qi?'done':k===qi?'cur':''}"></i>`;
  return h+'</div>';
}
function isNew(e){ const w=chState(CH).words[e.word]; return !w || w.box<0; }

function renderCard(){
  const e = QUEUE[qi];
  if(isNew(e)) { sub='guess'; conf=null; curGuess=''; renderGuess(e); }
  else renderRetrieve(e);
}

/* ── new word: PF guess → reveal ── */
function renderGuess(e){
  app.innerHTML = renderProg()+`
  <div class="stage-label">새 단어 — 맥락에서 추측 <span class="pace">${qi+1} / ${QUEUE.length}</span></div>
  <div class="card">
    <span class="badge new">NEW</span>
    <div class="ctx">${hl(e.ctx)}</div>
    <div class="src">${SRC_BASE} — Ch.${CH} (${e.sid})</div>
    <div class="q"><b>${e.word}</b> 의 뜻을 추측해 보세요.</div>
    <input class="guess" id="gin" autocomplete="off" placeholder="추측을 적어보세요 (모르면 비워두기)" oninput="curGuess=this.value">
    <div class="conf" id="conf">
      <button onclick="setConf('high',this)">자신 있음</button>
      <button onclick="setConf('mid',this)">애매함</button>
      <button onclick="setConf('low',this)">전혀 모름</button>
    </div>
    <div class="row"><button class="btn btn-main" id="revBtn" disabled onclick="toReveal()">확인하기 →</button></div>
  </div>`;
  document.getElementById('gin').focus();
}
function setConf(c,el){ conf=c; document.querySelectorAll('#conf button').forEach(b=>b.classList.remove('on')); el.classList.add('on'); document.getElementById('revBtn').disabled=false; }
function toReveal(){
  const e=QUEUE[qi];
  const guessShown = curGuess.trim()? esc(curGuess.trim()) : '<span style="opacity:.5">(추측 안 함)</span>';
  app.innerHTML = renderProg()+`
  <div class="stage-label">정답 확인 + 대조 <span class="pace">${qi+1} / ${QUEUE.length}</span></div>
  <div class="card">
    <div class="word-head"><span class="w">${e.word}</span><span class="pos">${e.pos}</span><span class="pron">${e.pron}</span>
      <button class="spk" onclick="speak('${esc(e.word)}')">🔊</button></div>
    <div class="mean">${e.mean}</div>
    ${e.base?`<div class="lemma">기본형: <b>${e.base.split(' — ')[0]}</b> — ${e.base.split(' — ').slice(1).join(' — ')}</div>`:''}
    <div class="contrast">
      <div class="mine"><div class="lbl">내 추측</div><div class="val">${guessShown}</div></div>
      <div class="real"><div class="lbl">실제 뜻</div><div class="val">${e.mean}</div></div>
    </div>
    <div class="ctx" style="margin-top:12px">${hl(e.ctx)}</div>
    ${e.note?`<div class="note">${e.note}</div>`:''}
    <div class="grade-q">내 추측은 얼마나 가까웠나요?</div>
    <div class="grade">
      <button class="g-ok" onclick="gradeNew('ok')">맞췄다</button>
      <button class="g-near" onclick="gradeNew('near')">비슷했다</button>
      <button class="g-miss" onclick="gradeNew('miss')">빗나갔다</button>
    </div>
  </div>`;
}
function gradeNew(g){
  const e=QUEUE[qi], w=wState(CH,e.word), c=chState(CH);
  if(g==='ok'){ w.box=1; sessLog.ok++; }
  else if(g==='near'){ w.box=1; sessLog.near++; }
  else { w.box=0; sessLog.miss++; }
  if(conf==='high'&&g==='miss') sessLog.over.push(e.word);
  w.due = c.sess + 1 + INTERVALS[w.box];
  save(); next();
}

/* ── review word: retrieval ── */
function renderRetrieve(e){
  const hasBlank = e.ctx.includes('⟦');
  app.innerHTML = renderProg()+`
  <div class="stage-label">복습 — 단어를 떠올려 보세요 <span class="pace">${qi+1} / ${QUEUE.length}</span></div>
  <div class="card">
    <span class="badge rev">REVIEW</span>
    <div class="q">뜻: <b>${e.mean}</b></div>
    ${hasBlank?`<div class="ctx">${blankCtx(e.ctx)}</div><div class="src">${SRC_BASE} — Ch.${CH}</div>`:''}
    <input class="guess" id="rin" autocomplete="off" placeholder="영어 단어" onkeydown="if(event.key==='Enter')checkRetr()">
    <div class="row">
      <button class="btn btn-main" onclick="checkRetr()">제출 →</button>
      <button class="btn btn-ghost" onclick="checkRetr(true)">모르겠다</button>
    </div>
    <div id="rfb"></div>
  </div>`;
  document.getElementById('rin').focus();
}
function checkRetr(giveUp){
  const e=QUEUE[qi], w=wState(CH,e.word), c=chState(CH);
  const ans = giveUp? "" : document.getElementById('rin').value;
  const target = norm(e.word.split(' ')[0]);
  const ok = norm(ans)===norm(e.word) || (norm(ans).length>=4 && (target.startsWith(norm(ans))||norm(ans).startsWith(target)));
  const fb=document.getElementById('rfb');
  if(ok){ w.box=Math.min(MAXBOX,w.box+1); sessLog.ok++;
    fb.className='feedback right'; fb.innerHTML=`정확합니다 — <b>${e.word}</b> ${e.pron}`; }
  else { w.box=0; sessLog.miss++;
    fb.className='feedback wrong'; fb.innerHTML=`정답: <b>${e.word}</b> ${e.pron} — ${e.mean}${e.base?` <span style="opacity:.8">(기본형 ${e.base})</span>`:''}${e.note?`<div class="note" style="margin-top:8px">${e.note}</div>`:''}`; }
  w.due = c.sess + 1 + INTERVALS[w.box];
  save();
  document.getElementById('rin').disabled=true;
  speak(e.word);
  setTimeout(next, ok?900:2400);
}

function next(){
  if(qi<QUEUE.length-1){ qi++; renderCard(); }
  else finishSession();
}

/* ── summary ── */
function finishSession(){
  const c=chState(CH); c.sess++; save();
  const deck=DECK[CH];
  const dist=[0,0,0,0,0]; let unseen=0;
  for(const e of deck){ const w=c.words[e.word]; if(!w||w.box<0)unseen++; else dist[w.box]++; }
  const mx=Math.max(...dist,1);
  app.innerHTML = `
  <div class="card summary">
    <div class="stage-label" style="justify-content:center">세션 ${c.sess} 완료 — Chapter ${CH}</div>
    <h2>${sessLog.miss===0?'전부 안착했습니다':'빗나간 단어는 다음 세션에 곧장 돌아옵니다'}</h2>
    <div class="stat-row">
      <div class="stat s-ok"><div class="n">${sessLog.ok}</div><div class="l">맞춤</div></div>
      <div class="stat s-near"><div class="n">${sessLog.near}</div><div class="l">비슷</div></div>
      <div class="stat s-miss"><div class="n">${sessLog.miss}</div><div class="l">빗나감</div></div>
    </div>
    ${sessLog.over.length?`<div class="feedback wrong" style="text-align:left">⚠️ <b>${sessLog.over.join(', ')}</b> — "자신 있음"이었지만 빗나갔습니다. 유창성 착각 주의 지점.</div>`:''}
    <div class="boxviz">
      ${dist.map((n,b)=>`<div class="bv"><div class="bar" style="height:${(n/mx*46)+3}px"></div><div class="bl">box${b}<br>${n}</div></div>`).join('')}
    </div>
    <div class="bl" style="font-size:.74rem;color:var(--muted)">미시작 ${unseen}개 · box가 오를수록 복습 간격이 멀어집니다</div>
    <div class="row" style="margin-top:16px">
      <button class="btn btn-ghost" style="flex:1" onclick="goHome()">챕터 목록</button>
      <button class="btn btn-main" onclick="startSession('${CH}')">한 세션 더 →</button>
    </div>
  </div>`;
}

goHome();
</script>
