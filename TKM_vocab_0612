"}, {"page": "182", "word": "surged", "sentence": "The crowd [[surged]] upward, rising in a wave.", "kor": "밀려들다/물밀듯이 올라오다", "eng": "moved upward in a wave"}, {"page": "182", "word": "miserably", "sentence": "Scout waited [[miserably]], wretched and unhappy.", "kor": "비참하게", "eng": "wretchedly; unhappily"}, {"page": "182", "word": "edged his way", "sentence": "Reverend Sykes [[edged his way]] through, working carefully along.", "kor": "조심스럽게 비집고 나아가다", "eng": "worked his way through carefully"}, {"page": "182", "word": "puffing", "sentence": "He came [[puffing]], breathing hard.", "kor": "헐떡이며", "eng": "breathing hard"}, {"page": "182", "word": "steered", "sentence": "He [[steered]] them up, guiding the children along.", "kor": "안내하다/이끌다", "eng": "guided"}, {"page": "182", "word": "front-row seats", "sentence": "He found them [[front-row seats]], the best ones at the front.", "kor": "앞줄 좌석", "eng": "the best seats, at the front"}, {"page": "182", "word": "Colored balcony", "sentence": "They sat in the [[Colored balcony]], the segregated upper gallery for Black spectators.", "kor": "흑인 전용 발코니 — 짐 크로우식 분리 좌석", "eng": "the segregated balcony where Black spectators were required to sit"}, {"page": "182", "word": "second-story veranda", "sentence": "It was like a [[second-story veranda]], a second-floor porch.", "kor": "2층 베란다", "eng": "a balcony like a second-floor porch"}, {"page": "182", "word": "sunburned", "sentence": "The jurors were [[sunburned]], browned by the sun.", "kor": "햇볕에 그을린", "eng": "browned by the sun"}, {"page": "182", "word": "lanky", "sentence": "They were [[lanky]], tall and thin.", "kor": "홀쭉한/키가 크고 마른", "eng": "tall and thin"}, {"page": "182", "word": "townfolk", "sentence": "These weren't [[townfolk]], not people from the town.", "kor": "읍내 사람들", "eng": "people who live in town"}, {"page": "182", "word": "struck", "sentence": "Some were [[struck]] from the jury, removed by a lawyer's challenge.", "kor": "기피 신청을 당하다 — 배심원에서 제외되다", "eng": "removed