<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Yena's Word Cards · TKAM 단어 카드</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css">
<link href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Noto+Sans+KR:wght@400;500;700&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --page:#cfc4ad; --page2:#bfb298;
    --card:#fbf8ef; --card-edge:#d9cfb6;
    --rule:rgba(85,99,108,.18); --margin:#a14334; --pen:#a14334;
    --ink:#2e2a22; --ink-soft:#5c5547; --label:#6e6757;
    --known:#4c7a4c; --again:#b58a1d; --shadow:rgba(46,42,34,.22);
  }
  *{box-sizing:border-box}
  [hidden]{display:none!important}
  html,body{margin:0}
  body{
    background:linear-gradient(180deg,var(--page) 0%, var(--page2) 100%);
    color:var(--ink); font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",-apple-system,sans-serif;
    min-height:100vh; padding:22px 14px 60px; -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:760px;margin:0 auto}

  header{margin:4px 4px 18px;display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap}
  .titleblock .eyebrow{font-family:"Courier Prime","Courier New",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:3px}
  .titleblock h1{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-weight:700;font-size:clamp(21px,5vw,30px);letter-spacing:.01em;margin:0;color:var(--ink)}
  .titleblock h1 .amp{font-style:italic;color:#3f5d3b}
  .titleblock .sub{font-size:13px;color:#5c5547;margin-top:5px;font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-style:italic}
  .credit{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-size:13px;color:#a14334;text-align:right;line-height:1.5;letter-spacing:.2px}

  .toolbar{display:flex;gap:8px;flex-wrap:wrap;align-items:center;background:#f1ecdd;border:1px solid #d6cbae;border-radius:12px;padding:9px 11px;margin:0 2px 14px}
  .chwrap{display:flex;align-items:center;gap:7px}
  .chwrap label{font-family:"Courier Prime","Courier New",monospace;font-size:11px;color:#5c5547;letter-spacing:.4px}
  .chsel{font:inherit;font-family:"Courier Prime","Courier New",monospace;font-size:12.5px;color:#2e2a22;background:#fbf8ef;border:1px solid #cdc0a0;border-radius:8px;padding:6px 9px;cursor:pointer}
  .seg{display:flex;background:#ded3b8;border-radius:9px;padding:3px;gap:3px}
  .seg button{font:inherit;font-size:12.5px;color:#5c5547;background:none;border:0;cursor:pointer;padding:6px 12px;border-radius:10px;letter-spacing:.2px}
  .seg button[aria-pressed="true"]{background:#2e2a22;color:#fbf8ef;font-weight:700}
  .toolbar .spacer{flex:1}
  .tbtn{font:inherit;font-size:12.5px;color:#5c5547;background:#ece5d2;border:1px solid #d6cbae;border-radius:8px;padding:7px 12px;cursor:pointer}
  .tbtn:hover{background:#ded3b8}
  .progress{font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:12.5px;color:#5c5547;letter-spacing:0;white-space:nowrap}
  .progress b{color:#2e2a22}
  .progress .k{color:var(--known)}

  .stage{perspective:1600px}
  .card{
    position:relative;background:linear-gradient(180deg,#fbf8ef,#f1ecdd);
    border:1px solid var(--card-edge);border-radius:10px;
    box-shadow:0 16px 34px -16px var(--shadow), 0 1px 0 #f1ecdd inset;
    padding:26px 26px 22px 58px;color:var(--ink);
    background-image:repeating-linear-gradient(180deg, transparent 0 37px, var(--rule) 37px 38px);
    background-position:0 64px;min-height:300px;
  }
  .card:before{content:"";position:absolute;top:0;bottom:0;left:42px;width:2px;background:var(--margin);opacity:.55}
  .cardtop{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
  .chip{font-family:"Courier Prime","Courier New",monospace;font-size:11px;letter-spacing:.5px;color:#5c5547;border:1px solid #d6cbae;border-radius:30px;padding:3px 10px;background:#f1ecdd}
  .counter{font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:12px;color:#857c69;letter-spacing:0}
  .knownflag{font-family:"Courier Prime","Courier New",monospace;font-size:11px;color:var(--known);letter-spacing:.4px;display:none}
  .card.is-known .knownflag{display:inline}

  .sentence{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-size:clamp(20px,3.5vw,25px);line-height:1.62;color:#2e2a22;margin:6px 0 4px;letter-spacing:.1px}
  .target{font-family:"Courier Prime","Courier New",monospace;font-size:.86em;letter-spacing:.3px;padding:0 .12em 1px;border-bottom:2px solid var(--margin);color:#2e2a22;cursor:pointer}
  .target:hover{background:#f0e7d2}
  .topright{display:flex;align-items:center;gap:10px}
  .speak{flex:none;cursor:pointer;background:#ece5d2;border:1px solid #d6cbae;border-radius:30px;width:30px;height:30px;display:inline-flex;align-items:center;justify-content:center;color:#5c5547;padding:0;transition:background .12s,color .12s}
  .speak:hover{background:#d6c9a8}
  .speak.speaking{background:#324a2f;color:#fbf8ef;border-color:#324a2f}
  .speak svg{display:block}
  .hint{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-style:italic;font-size:13.5px;color:#7a7263;margin-top:16px}

  .reveal{margin-top:20px;display:inline-flex;align-items:center;gap:10px;font:inherit;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:13.5px;font-weight:500;letter-spacing:0;background:#324a2f;color:#fbf8ef;border:0;border-radius:9px;padding:11px 16px;cursor:pointer}
  .reveal:hover{background:#283e26}
  .reveal kbd{font-family:inherit;background:rgba(255,255,255,.18);border-radius:4px;padding:1px 6px;font-size:11px}
  .card.s2 .reveal{display:none}

  .answer{display:none;margin-top:18px;border-top:1px dashed #cfc3a3;padding-top:14px}
  .card.s1 .answer,.card.s2 .answer{display:block}
  .answer .word{font-family:"Courier Prime","Courier New",monospace;font-size:14px;color:#5c5547;letter-spacing:.4px;margin-bottom:6px}
  .answer .eng{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-style:italic;font-size:clamp(21px,4.4vw,26px);line-height:1.42;color:#a14334;margin-top:2px;transform:rotate(-.35deg);transform-origin:left center}
  .answer .kor{display:none;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:clamp(18px,3.4vw,22px);font-weight:500;color:var(--pen);line-height:1.45;margin-top:10px}
  .card.s2 .answer .kor{display:block}

  .actions{display:flex;gap:9px;margin-top:20px;flex-wrap:wrap;align-items:center}
  .act{font:inherit;font-size:13px;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;cursor:pointer;border-radius:9px;padding:10px 15px;border:1px solid transparent;letter-spacing:.2px}
  .act.know{background:#e7ecdf;color:var(--known);border-color:#c9d4bd}
  .act.know:hover{background:#dde5d0}
  .act.again{background:#f0e7d2;color:var(--again);border-color:#e0d0a4}
  .act.again:hover{background:#ead9b8}
  .act .kbd{font-family:"Courier Prime","Courier New",monospace;opacity:.6;font-size:11px;margin-left:5px}
  .nav{display:flex;gap:9px;margin-left:auto}
  .nav button{font:inherit;font-size:13px;cursor:pointer;background:#ece5d2;border:1px solid #cdc0a0;color:#443f33;border-radius:9px;padding:10px 14px;font-family:"Courier Prime","Courier New",monospace;letter-spacing:.3px}
  .nav button:hover{background:#d6c9a8}

  .list{display:grid;gap:12px}
  .lcard{background:linear-gradient(180deg,#fbf8ef,#f1ecdd);border:1px solid var(--card-edge);border-radius:10px;padding:14px 16px 15px 40px;position:relative;color:var(--ink);box-shadow:0 8px 18px -14px var(--shadow)}
  .lcard:before{content:"";position:absolute;top:0;bottom:0;left:26px;width:2px;background:var(--margin);opacity:.5}
  .lcard .lp{font-family:"Courier Prime","Courier New",monospace;font-size:10.5px;color:#857c69;letter-spacing:.4px}
  .lcard .ls{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-size:17.5px;line-height:1.55;color:#2e2a22;margin-top:4px}
  .lhead{display:flex;align-items:center;gap:9px;margin-bottom:5px}
  .lhead .hw{font-family:"Courier Prime","Courier New",monospace;font-size:18px;color:#2e2a22;letter-spacing:.3px}
  .speak.sm{width:24px;height:24px}
  .leng{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-style:italic;color:#a14334;font-size:16.5px;line-height:1.4}
  .lkor{font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;color:var(--pen);font-size:15.5px;font-weight:500;line-height:1.45;margin-top:2px}
  .lsent{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-size:14.5px;line-height:1.55;color:#5c5547;margin-top:9px;padding-top:9px;border-top:1px dashed #d9cfb6}
  .lcard.is-known{outline:2px solid #c9d4bd}
  .lcard .check{position:absolute;top:10px;right:12px;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:11.5px;color:var(--known);opacity:0}
  .lcard.is-known .check{opacity:1}

  .search{width:100%;font:inherit;font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-size:15px;color:#2e2a22;background:#f1ecdd;border:1px solid #d6cbae;border-radius:10px;padding:11px 14px;margin:0 2px 14px}
  .search::placeholder{color:#968d79}
  .empty{color:#7a7263;font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-style:italic;text-align:center;padding:40px 0}

  footer{margin:26px 6px 0;font-size:12px;color:#5c5547;font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-style:italic;line-height:1.6}
  footer b{color:#2e2a22;font-style:normal}

  @media (max-width:520px){
    .card{padding:22px 18px 18px 46px}
    .card:before{left:32px}
    .nav{margin-left:0;width:100%}
    .nav button{flex:1}
  }
  @media (prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}.answer .kor,.answer .eng{transform:none}}
  :focus-visible{outline:2px solid #a14334;outline-offset:2px;border-radius:6px}

  /* ---- quiz ---- */
  .qbar{display:flex;justify-content:space-between;align-items:baseline;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:12.5px;color:#5c5547;letter-spacing:0;margin:2px 4px 12px}
  .qbar .qscore{color:var(--known)}
  .qcard{position:relative;background:linear-gradient(180deg,#fbf8ef,#f1ecdd);border:1px solid var(--card-edge);border-radius:10px;box-shadow:0 16px 34px -16px var(--shadow),0 1px 0 #f1ecdd inset;padding:24px 24px 22px;min-height:280px}
  .qlead{font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:12.5px;color:#857c69;letter-spacing:0;margin-bottom:10px}
  .qsentence{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-size:clamp(19px,3.3vw,24px);line-height:1.6;color:#2e2a22;margin:0 0 20px}
  .qopts{display:flex;flex-direction:column;gap:9px}
  .qopt{font:inherit;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:16px;text-align:left;cursor:pointer;background:#fbf8ef;border:1px solid #d6cbae;border-radius:9px;padding:11px 15px;color:#2e2a22;transition:background .12s,border-color .12s}
  .qopt:hover:not(:disabled){background:#ece5d2;border-color:#c2b48f}
  .qopt:disabled{cursor:default}
  .qopt.correct{background:#e7ecdf;border-color:var(--known);color:#324a2f;font-weight:700}
  .qopt.wrong{background:#efdfdb;border-color:var(--margin);color:#8a3a2d}
  .qfeed{min-height:24px;margin:15px 2px 0;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:14.5px;color:#2e2a22;line-height:1.55}
  .qfeed .ok{color:var(--known);font-weight:700} .qfeed .no{color:var(--margin);font-weight:700}
  .qfeed b{font-family:"Courier Prime","Courier New",monospace;font-size:13px}
  .qnext{margin-top:16px;font:inherit;font-size:14px;background:#2e2a22;color:#fbf8ef;border:0;border-radius:8px;padding:10px 18px;cursor:pointer;font-weight:700;letter-spacing:.3px}
  .qnext:hover{background:#3f5d3b}
  .qdone{text-align:center;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:18px;color:#2e2a22;padding:50px 0;line-height:1.8}
  .qdone b{font-family:"Courier Prime","Courier New",monospace;color:var(--known);font-size:22px}
  .qdone .tbtn{margin-top:18px;font-size:14px}

  /* ---- round bar + sort piles (card mode) ---- */
  .roundbar{display:flex;justify-content:flex-end;margin:-4px 4px 12px}
  .roundpill{font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:12.5px;color:#9a7517;background:#f1ecdd;border:1px solid #e0d0a4;border-radius:20px;padding:5px 13px;letter-spacing:0}
  .piles{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}
  .pile{background:#f1ecdd;border:1px solid #d9cfb6;border-radius:11px;padding:11px 11px 12px;display:flex;flex-direction:column;min-height:96px}
  .pile.k{border-top:3px solid var(--known)} .pile.r{border-top:3px solid var(--again)}
  .pile h4{margin:0 0 9px;font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:12.5px;font-weight:500;letter-spacing:0;display:flex;align-items:center;gap:7px}
  .pile.k h4{color:var(--known)} .pile.r h4{color:var(--again)}
  .pile h4 em{font-style:normal;background:#ece5d2;border-radius:20px;padding:1px 9px;font-size:11px;color:#5c5547}
  .pilebody{display:flex;flex-direction:column;gap:5px;max-height:300px;overflow-y:auto;padding-right:3px;scrollbar-width:thin}
  .pilebody::-webkit-scrollbar{width:7px} .pilebody::-webkit-scrollbar-thumb{background:#cdc0a0;border-radius:4px}
  .pchip{display:flex;align-items:baseline;gap:7px;width:100%;text-align:left;font:inherit;cursor:pointer;background:#fbf8ef;border:1px solid #d6cbae;border-radius:10px;padding:5px 9px;transition:box-shadow .12s,transform .08s}
  .pchip:hover{box-shadow:0 3px 9px -5px var(--shadow);transform:translateY(-1px)}
  .pchip.k:hover{border-color:var(--known)} .pchip.r:hover{border-color:var(--again)}
  .pchip .w{font-family:"Courier Prime","Courier New",monospace;font-size:12.5px;color:#2e2a22;flex:0 1 auto;max-width:48%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .pchip .sep{color:#c2b48f;flex:none}
  .pchip .d{font-family:"Libre Caslon Text",Georgia,"Pretendard Variable",serif;font-size:13px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .pchip.k .d{color:#4c7a4c} .pchip.r .d{color:#9a7517}
  .pile .pempty{font-family:"Pretendard Variable",Pretendard,"Noto Sans KR",sans-serif;font-size:13px;color:#857c69;padding:12px 2px}
  @media (max-width:520px){ .piles{grid-template-columns:1fr} }
</style>

<div class="wrap">
  <header>
    <div class="titleblock">
      <div class="eyebrow">To Kill a Mockingbird · Vocabulary</div>
      <h1>Yena<span class="amp">’s</span> Word Cards</h1>
      <div class="sub">단어 카드 — 문맥으로 뜻 유추 → 영어 뜻 → 한국어 뜻</div>
    </div>
    <div class="credit" id="credit">CHAPTER 1<br>Yena's Scrapbook</div>
  </header>

  <div class="toolbar">
    <div class="chwrap">
      <label for="chSel">CH.</label>
      <select class="chsel" id="chSel" aria-label="챕터 선택"></select>
    </div>
    <div class="seg" role="group" aria-label="보기 방식">
      <button id="mCard" aria-pressed="true">카드</button>
      <button id="mList" aria-pressed="false">목록</button>
      <button id="mQuiz" aria-pressed="false">퀴즈</button>
    </div>
    <div class="seg" role="group" aria-label="필터" id="filterSeg">
      <button id="fAll" aria-pressed="true">전체</button>
      <button id="fLeft" aria-pressed="false">안 외운 것</button>
    </div>
    <button class="tbtn" id="shuffle" title="섞기">↺ 섞기</button>
    <div class="spacer"></div>
    <div class="progress" id="progress"></div>
  </div>

  <input class="search" id="search" type="search" placeholder="단어 검색 (예: piety, 박해, taciturn)…" hidden>

  <div class="roundbar" id="roundbar" hidden></div>

  <div class="stage" id="cardStage">
    <div class="card" id="card">
      <div class="cardtop">
        <span class="chip" id="chip">p.1</span>
        <span class="topright">
          <span class="counter" id="counter"></span>
          <button class="speak" id="speakBtn" title="발음 듣기 (영국 발음)" aria-label="발음 듣기"><svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.06c1.48-.74 2.5-2.26 2.5-4.03zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg></button>
        </span>
      </div>
      <p class="sentence" id="sentence"></p>
      <button class="reveal" id="revealBtn"><span id="revealLbl">영어 뜻 보기</span> <kbd>space</kbd></button>
      <div class="answer">
        <div class="word" id="aWord"></div>
        <div class="eng" id="aEng"></div>
        <div class="kor" id="aKor"></div>
      </div>
      <div class="actions">
        <button class="act know" id="bKnow">✓ 외웠어요<span class="kbd">1</span></button>
        <button class="act again" id="bAgain">↻ 다시 볼래요<span class="kbd">2</span></button>
        <button class="tbtn" id="restartCh" hidden>↺ 처음부터 다시</button>
      </div>
    </div>

    <div class="piles">
      <div class="pile k">
        <h4>✓ 외웠어요 <em id="kCount">0</em></h4>
        <div class="pilebody" id="kpile"></div>
      </div>
      <div class="pile r">
        <h4>↻ 다시 볼래요 <em id="rCount">0</em></h4>
        <div class="pilebody" id="rpile"></div>
      </div>
    </div>
  </div>

  <div class="list" id="list" hidden></div>

  <div class="quizstage" id="quizStage" hidden></div>
</div>

