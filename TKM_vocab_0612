th tears.", "kor": "안개 낀 듯한", "eng": "hazy (with tears)"}, {"page": "319", "word": "cross-eyed", "sentence": "She'd looked till nearly [[cross-eyed]], her eyes crossing.", "kor": "사시가 되도록", "eng": "with eyes crossed"}, {"page": "319", "word": "get grown", "sentence": "She'd [[get grown]] before she knew it, grow up (dialect).", "kor": "어른이 되다 (방언)", "eng": "(dialect) grow up"}, {"page": "319", "word": "his children needed him", "sentence": "She understood at last how [[his children needed him]] — Boo, the watching guardian next door.", "kor": "그의 아이들에게 그가 필요했다", "eng": "the porch insight — Boo as watching neighbor-guardian"}, {"page": "320", "word": "reviving", "sentence": "Jem was [[reviving]], coming back to alertness.", "kor": "기운을 차리다", "eng": "coming back to alertness"}, {"page": "320", "word": "settin' up", "sentence": "Atticus would be [[settin' up]] with him, staying up (dialect).", "kor": "자지 않고 앉아 있기 (방언)", "eng": "(dialect) staying up"}, {"page": "320", "word": "suit yourself", "sentence": "\"[[Suit yourself]],\" he said — do as you please.", "kor": "마음대로 하렴", "eng": "do as you please"}, {"page": "320", "word": "puzzled", "sentence": "Scout looked [[puzzled]], confused.", "kor": "어리둥절한", "eng": "confused"}, {"page": "320", "word": "amiable", "sentence": "Atticus was [[amiable]], friendly and pleasant.", "kor": "정감 있는", "eng": "friendly and pleasant"}, {"page": "320", "word": "acquiescence", "sentence": "He gave a quiet [[acquiescence]], consent without protest.", "kor": "묵인/순순한 동의", "eng": "quiet consent without protest"}, {"page": "320", "word": "The Gray Ghost", "sentence": "He read [[The Gray Ghost]], the boys' adventure book.", "kor": "회색 유령 (책 제목)", "eng": "the boys' adventure book Atticus reads aloud"}, {"page": "320", "word": "pointedly", "sentence": "Scout asked [[pointedly]], with deliberate emphasis.", "kor": "의미심장하게", "eng": "with deliberate emphasis"}, {"page": "321", "word": "leastways", "sentence": "\"[[Leastways]] he tried,\" she said — at least (dialect).", "kor": "적어도 (방언)", "eng": "(dialect) at least"}, {"page": "321", "word": "willed myself", "sentence": "She [[willed myself]] to stay awake, forcing it.", "kor": "억지로 ~하려 애쓰다", "eng": "forced myself by will"}, {"page": "321", "word": "snug", "sentence": "She felt [[snug]], warm and secure.", "kor": "포근한", "eng": "warm and secure"}, {"page": "321", "word": "chased him 'round", "sentence": "They [[chased him 'round]] the book, pursuing the falsely-blamed boy.", "kor": "그를 쫓아다녔다", "eng": "pursued him (the plot of The Gray Ghost)"}, {"page": "321", "word": "hadn't done any of those things", "sentence": "He [[hadn't done any of those things]], the misjudged boy proved innocent.", "kor": "그런 짓을 하나도 안 했어요", "eng": "the misjudged boy proved innocent"}, {"page": "321", "word": "he was real nice", "sentence": "\"[[He was real nice]],\" she murmured — of the storybook boy, and of Boo.", "kor": "알고 보니 정말 착한 사람이었어요", "eng": "Scout's sleepy summary — of Stoner's Boy, and of Boo"}, {"page": "321", "word": "most people are", "sentence": "\"[[Most people are]], Scout,\" Atticus said — nice, after all.", "kor": "대부분의 사람들이 그렇단다", "eng": "Atticus's reply: '...when you finally see them'"}, {"page": "321", "word": "when you finally see them", "sentence": "\"...[[when you finally see them]],\" he finished — the novel's last lesson on truly seeing.", "kor": "마침내 그들을 제대로 보게 되면", "eng": "the novel's last lesson on seeing"}, {"page": "322", "word": "turn out the light", "sentence": "He went to [[turn out the light]], switching it off.", "kor": "불을 끄다", "eng": "switch off the light"}, {"page": "322", "word": "he would be there all night", "sentence": "[[He would be there all night]], Atticus keeping vigil by Jem.", "kor": "그는 밤새 그 곁에 있을 것이었다", "eng": "Atticus's vigil by Jem"}, {"page": "322", "word": "when Jem waked up in the morning", "sentence": "He'd be there [[when Jem waked up in the morning]], the closing promise of morning.", "kor": "Jem이 아침에 깨어날 때", "eng": "the closing clause — morning promised"}]};
const chapterKeys = Object.keys(CHAPTERS).sort((a,b)=>(+a)-(+b));

/* persistence: localStorage (survives closing) → window.storage → memory */
const mem={};
function lsGet(k){ try{ const v=localStorage.getItem(k); return v==null?null:JSON.parse(v); }catch(e){ return undefined; } }
function lsSet(k,v){ try{ localStorage.setItem(k, JSON.stringify(v)); return true; }catch(e){ return false; } }
const store={
  async get(k){
    const v=lsGet(k); if(v!==undefined) return v;
    try{ if(window.storage?.get){const r=await window.storage.get(k,false); return r?r.value:null;} }catch(e){}
    return (k in mem)?mem[k]:null;
  },
  async set(k,v){
    if(lsSet(k,v)) return;
    try{ if(window.storage?.set){await window.storage.set(k,v,false); return;} }catch(e){}
    mem[k]=v;
  }
};

let curCh = chapterKeys[0];
let DATA = CHAPTERS[curCh];
let KEY = "tkam_known_ch"+curCh;
let RKEY = "tkam_review_ch"+curCh;
let ROKEY = "tkam_round_ch"+curCh;
let known = new Set();
let review = new Set();
let order = DATA.map((_,i)=>i);
let round = 1;
let stage = 0, mode = "card";
let filterLeft=false, pos=0;          // list mode only
let rolling = false;                  // round-rollover guard

/* quiz state */
let quizPool=[], quizPos=0, quizScore=0, quizTries=0, quizAnswered=false;

const $ = id => document.getElementById(id);
const renderSentence = s => s.replace(/\[\[(.+?)\]\]/g,'<span class="target" role="button" tabindex="0" title="발음 듣기">$1</span>');
const escapeHtml = s => s.replace(/[&<>]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;"}[c]));
const targetOf = d => (d.sentence.match(/\[\[(.+?)\]\]/)||[])[1]||d.word;
let curTarget = "";

/* ---- pronunciation (Web Speech API, prefer British en-GB) ---- */
let ukVoice = null;
function pickVoice(){
  if(!("speechSynthesis" in window)) return;
  const vs = speechSynthesis.getVoices() || [];
  ukVoice =
    vs.find(v=>/en[-_]GB/i.test(v.lang)) ||
    vs.find(v=>/\b(British|UK|Daniel|Kate|Serena|Arthur|Sonia|Oliver|Libby|Ryan)\b/i.test(v.name)) ||
    vs.find(v=>/^en/i.test(v.lang)) ||
    vs[0] || null;
}
if("speechSynthesis" in window){
  pickVoice();
  speechSynthesis.onvoiceschanged = pickVoice;
}
function speak(text, btn){
  if(!("speechSynthesis" in window) || !text) return;
  const word = text.replace(/[“”"]/g,"").trim();
  if(!word) return;
  try{
    speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(word);
    u.lang = "en-GB";
    if(ukVoice) u.voice = ukVoice;
    u.rate = 0.9; u.pitch = 1;
    if(btn){ u.onstart=()=>btn.classList.add("speaking"); u.onend=u.onerror=()=>btn.classList.remove("speaking"); }
    speechSynthesis.speak(u);
  }catch(e){}
}

/* draw queue = cards not yet classified, in current order */
function queue(){ return order.filter(i=>!known.has(i) && !review.has(i)); }
function persist(){ store.set(KEY,[...known]); store.set(RKEY,[...review]); store.set(ROKEY,round); }

/* ---- stage reveal (3-step) ---- */
function setStage(s){
  stage=s;
  const c=$("card");
  c.classList.toggle("s1", s>=1);
  c.classList.toggle("s2", s>=2);
  $("revealLbl").textContent = s===0 ? "영어 뜻 보기" : "한국어 뜻 보기";
}
function advance(){ if(stage<2) setStage(stage+1); }

/* ---- card (top draw pile) ---- */
function paintCard(){
  const q=queue(), card=$("card");
  const ans=card.querySelector(".answer");
  $("revealBtn").style.display="";
  ans.style.display=""; $("bKnow").style.display=""; $("bAgain").style.display="";
  $("restartCh").hidden=true;
  if(q.length===0){
    const allDone = known.size>=DATA.length;
    $("sentence").innerHTML = allDone
      ? "🎉 이 챕터 단어를 모두 외웠어요!<br>처음부터 다시 볼 수 있어요."
      : (round+"회독 완성! 복습할 단어를 다시 가져옵니다…");
    $("chip").textContent=""; $("counter").textContent="";
    $("revealBtn").style.display="none";
    ans.style.display="none"; $("bKnow").style.display="none"; $("bAgain").style.display="none";
    $("restartCh").hidden=!allDone;
    setStage(0);
    return;
  }
  const idx=q[0], d=DATA[idx];
  curTarget=targetOf(d);
  $("chip").textContent="p."+d.page;
  $("counter").textContent="남은 "+q.length+"장";
  $("sentence").innerHTML=renderSentence(d.sentence);
  const target=targetOf(d);
  $("aWord").textContent="“"+target+"”";
  $("aEng").textContent=d.eng;
  $("aKor").textContent=d.kor;
  setStage(0);
}
function paintRound(){
  $("roundbar").innerHTML='<span class="roundpill">'+round+'회독 중 · 남은 카드 '+queue().length+'</span>';
}

/* classify current top card */
function classify(val){
  if(rolling) return;
  const q=queue(); if(!q.length) return;
  const idx=q[0];
  if(val){ known.add(idx); review.delete(idx); }
  else { review.add(idx); known.delete(idx); }
  persist();
  renderPiles();
  if(queue().length===0 && review.size>0){ roundComplete(); }
  else { paintCard(); paintRound(); }
}
function roundComplete(){
  rolling=true;
  paintCard(); paintRound();      // shows "N회독 완성!" message
  setTimeout(()=>{
    const rev=[...review];
    review=new Set();
    order = rev.concat(order.filter(i=>!rev.includes(i)));   // review cards lead next round
    round++;
    persist();
    rolling=false;
    renderPiles(); paintRound(); paintCard();
  }, 1200);
}
function restartChapter(){
  known=new Set(); review=new Set(); round=1;
  order=DATA.map((_,i)=>i);
  persist();
  renderPiles(); paintRound(); paintCard();
}

/* ---- sort piles (newest on top) ---- */
function pchip(i,cls){
  const d=DATA[i];
  return '<button class="pchip '+cls+'" data-i="'+i+'"><span class="w">'+escapeHtml(targetOf(d))+'</span><span class="sep">—</span><span class="d">'+escapeHtml(d.kor)+'</span></button>';
}
function renderPiles(){
  $("kCount").textContent=known.size;
  $("rCount").textContent=review.size;
  const kArr=[...known].reverse(), rArr=[...review].reverse();
  const kp=$("kpile"), rp=$("rpile");
  kp.innerHTML = kArr.length ? kArr.map(i=>pchip(i,"k")).join("") : '<div class="pempty">아직 없어요.</div>';
  rp.innerHTML = rArr.length ? rArr.map(i=>pchip(i,"r")).join("") : '<div class="pempty">아직 없어요.</div>';
  kp.querySelectorAll(".pchip").forEach(el=>el.onclick=()=>pullBack(+el.dataset.i,"k"));
  rp.querySelectorAll(".pchip").forEach(el=>el.onclick=()=>pullBack(+el.dataset.i,"r"));
}
function pullBack(i,cls){
  if(rolling) return;
  if(cls==="k") known.delete(i); else review.delete(i);
  order = [i].concat(order.filter(x=>x!==i));   // bring to top of draw pile
  persist();
  renderPiles(); paintCard(); paintRound();
}

/* ---- list mode ---- */
function visibleOrder(){ return filterLeft ? order.filter(i=>!known.has(i)) : order; }
function buildList(){
  const root=$("list"); root.innerHTML="";
  const q=($("search").value||"").trim().toLowerCase();
  let v=visibleOrder();
  if(q) v=v.filter(i=>{const d=DATA[i];return (d.word+" "+d.kor+" "+d.eng+" "+d.sentence).toLowerCase().includes(q);});
  if(!v.length){ root.innerHTML='<div class="empty">검색 결과가 없어요.</div>'; return; }
  for(const i of v){
    const d=DATA[i];
    const head=escapeHtml(targetOf(d));
    const el=document.createElement("div");
    el.className="lcard"+(known.has(i)?" is-known":"");
    el.innerHTML=
      '<div class="lp">p.'+d.page+'</div><span class="check">✓ 외움</span>'+
      '<div class="lhead"><span class="hw">'+head+'</span>'+
        '<button class="speak sm" title="발음 듣기 (영국 발음)" aria-label="발음 듣기" data-w="'+head.replace(/"/g,'&quot;')+'"><svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.06c1.48-.74 2.5-2.26 2.5-4.03zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg></button>'+
      '</div>'+
      '<div class="leng">'+escapeHtml(d.eng)+'</div>'+
      '<div class="lkor">'+escapeHtml(d.kor)+'</div>'+
      '<div class="lsent">'+renderSentence(d.sentence)+'</div>';
    el.addEventListener("dblclick",()=>{ if(known.has(i)){known.delete(i);} else {known.add(i); review.delete(i);} persist(); el.classList.toggle("is-known"); paintProgress(); });
    root.appendChild(el);
  }
  root.querySelectorAll(".speak.sm").forEach(b=>{
    b.onclick=e=>{ e.stopPropagation(); speak(b.dataset.w, b); };
    b.ondblclick=e=>e.stopPropagation();
  });
}
function paintProgress(){ $("progress").innerHTML='<b>'+DATA.length+'</b> 단어 · <span class="k">외움 '+known.size+'</span>'; }

/* ---- quiz (multiple choice, current chapter) ---- */
function startQuiz(){
  quizPool=DATA.map((_,i)=>i);
  for(let i=quizPool.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[quizPool[i],quizPool[j]]=[quizPool[j],quizPool[i]];}
  quizPos=0; quizScore=0; quizTries=0;
  renderQuiz();
}
function renderQuiz(){
  const st=$("quizStage");
  if(quizPos>=quizPool.length){
    st.innerHTML='<div class="qdone">퀴즈 완료!<br><b>'+quizScore+' / '+quizTries+'</b> 맞혔어요.<br><button class="tbtn" id="qrestart">다시 풀기 ↺</button></div>';
    $("qrestart").onclick=startQuiz; return;
  }
  const idx=quizPool[quizPos], d=DATA[idx];
  const others=DATA.map((_,i)=>i).filter(i=>i!==idx);
  for(let i=others.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[others[i],others[j]]=[others[j],others[i]];}
  let optIdx=[idx, ...others.slice(0,3)];
  for(let i=optIdx.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[optIdx[i],optIdx[j]]=[optIdx[j],optIdx[i]];}
  quizAnswered=false;
  let opts='';
  optIdx.forEach((i,n)=>{ opts+='<button class="qopt" data-correct="'+(i===idx?1:0)+'"><span style="color:#968d79;font-family:\'Courier Prime\',monospace;font-size:12px;margin-right:8px">'+(n+1)+'</span>'+escapeHtml(DATA[i].kor)+'</button>'; });
  st.innerHTML=
    '<div class="qbar"><span class="qprog">문제 '+(quizPos+1)+' / '+quizPool.length+'</span><span class="qscore">맞음 '+quizScore+' / '+quizTries+'</span></div>'+
    '<div class="qcard"><div class="qlead">굵게 표시된 단어의 뜻은?</div><p class="qsentence">'+renderSentence(d.sentence)+'</p>'+
    '<div class="qopts">'+opts+'</div><div class="qfeed" id="qfeed"></div>'+
    '<button class="qnext" id="qnext" hidden>다음 문제 →</button></div>';
  st.querySelectorAll(".qopt").forEach(b=>b.addEventListener("click",()=>answerQuiz(b,d)));
  $("qnext").onclick=()=>{ quizPos++; renderQuiz(); };
}
function answerQuiz(btn,d){
  if(quizAnswered)return; quizAnswered=true; quizTries++;
  const correct=btn.dataset.correct==="1"; if(correct)quizScore++;
  $("quizStage").querySelectorAll(".qopt").forEach(b=>{ b.disabled=true; if(b.dataset.correct==="1")b.classList.add("correct"); });
  if(!correct)btn.classList.add("wrong");
  $("qfeed").innerHTML=(correct?'<span class="ok">맞아요!</span> ':'<span class="no">아쉬워요.</span> ')+'<span class="target" role="button" tabindex="0" title="발음 듣기">'+escapeHtml(targetOf(d))+'</span> — '+escapeHtml(d.eng);
  const sc=document.querySelector(".qscore"); if(sc) sc.textContent='맞음 '+quizScore+' / '+quizTries;
  $("qnext").hidden=false;
}

/* ---- mode / filter / chapter ---- */
function setMode(m){
  mode=m;
  $("mCard").setAttribute("aria-pressed", m==="card");
  $("mList").setAttribute("aria-pressed", m==="list");
  $("mQuiz").setAttribute("aria-pressed", m==="quiz");
  $("cardStage").hidden=m!=="card";
  $("roundbar").hidden=m!=="card";
  $("list").hidden=m!=="list";
  $("search").hidden=m!=="list";
  $("quizStage").hidden=m!=="quiz";
  $("filterSeg").style.display=(m==="list")?"":"none";
  $("shuffle").style.display=(m==="card"||m==="list")?"":"none";
  $("progress").style.display=(m==="card"||m==="list")?"":"none";
  if(m==="card"){ renderPiles(); paintRound(); paintCard(); }
  else if(m==="list"){ buildList(); }
  else if(m==="quiz"){ startQuiz(); }
}
function setFilter(left){
  filterLeft=left;
  $("fAll").setAttribute("aria-pressed", !left);
  $("fLeft").setAttribute("aria-pressed", left);
  if(mode==="list") buildList();
}
function shuffle(){
  if(mode!=="card" && mode!=="list") return;
  for(let i=order.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[order[i],order[j]]=[order[j],order[i]];}
  if(mode==="card"){ paintCard(); paintRound(); } else buildList();
}
function loadChapter(ch){
  curCh=ch; DATA=CHAPTERS[ch];
  KEY="tkam_known_ch"+ch; RKEY="tkam_review_ch"+ch; ROKEY="tkam_round_ch"+ch;
  known=new Set(); review=new Set(); round=1; order=DATA.map((_,i)=>i); filterLeft=false; rolling=false;
  $("credit").innerHTML="CHAPTER "+ch+"<br>Yena's Scrapbook";
  $("fAll").setAttribute("aria-pressed", true);
  $("fLeft").setAttribute("aria-pressed", false);
  paintProgress();
  if(mode==="card"){ renderPiles(); paintRound(); paintCard(); }
  else if(mode==="list"){ buildList(); }
  (async()=>{
    try{
      const [sk,sr,so]=await Promise.all([
        Promise.race([store.get(KEY),  new Promise(r=>setTimeout(()=>r(null),1500))]),
        Promise.race([store.get(RKEY), new Promise(r=>setTimeout(()=>r(null),1500))]),
        Promise.race([store.get(ROKEY),new Promise(r=>setTimeout(()=>r(null),1500))])
      ]);
      if(curCh===ch){
        if(Array.isArray(sk)) known=new Set(sk);
        if(Array.isArray(sr)) review=new Set(sr);
        if(typeof so==="number" && so>=1) round=so;
        paintProgress();
        if(mode==="card"){ renderPiles(); paintRound(); paintCard(); }
        else if(mode==="list"){ buildList(); }
      }
    }catch(e){}
  })();
}

/* ---- wire ---- */
(function initChSel(){
  const sel=$("chSel");
  for(const k of chapterKeys){ const o=document.createElement("option"); o.value=k; o.textContent="Chapter "+k; sel.appendChild(o); }
  sel.value=curCh;
  sel.addEventListener("change", ()=>loadChapter(sel.value));
})();
$("mCard").onclick=()=>setMode("card");
$("mList").onclick=()=>setMode("list");
$("mQuiz").onclick=()=>setMode("quiz");
$("fAll").onclick=()=>setFilter(false);
$("fLeft").onclick=()=>setFilter(true);
$("shuffle").onclick=shuffle;
$("revealBtn").onclick=advance;
$("speakBtn").onclick=()=>speak(curTarget, $("speakBtn"));
document.addEventListener("click",e=>{ const t=e.target.closest&&e.target.closest(".target"); if(t) speak(t.textContent); });
$("bKnow").onclick=()=>classify(true);
$("bAgain").onclick=()=>classify(false);
$("restartCh").onclick=restartChapter;
$("search").addEventListener("input", buildList);
document.addEventListener("keydown",e=>{
  if(e.target.tagName==="INPUT"||e.target.tagName==="SELECT") return;
  if(mode==="card"){
    if(e.code==="Space"){e.preventDefault(); advance();}
    else if(e.key==="1"){classify(true);}
    else if(e.key==="2"){classify(false);}
  } else if(mode==="quiz"){
    if(["1","2","3","4"].includes(e.key)){
      const opts=$("quizStage").querySelectorAll(".qopt");
      const b=opts[+e.key-1]; if(b && !b.disabled) b.click();
    } else if(e.code==="Space"||e.key==="Enter"){
      const n=$("qnext"); if(n && !n.hidden){ e.preventDefault(); n.click(); }
    }
  }
});

/* ---- init ---- */
loadChapter(curCh);

</script>
