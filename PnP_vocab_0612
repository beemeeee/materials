 affected by the difference, her sister's situation remained the same, her peace equally wounded.","x":1,"f":"wounded","en":"cause injuries or bodily harm to","ko":"상처(를 입히다), 마음을 다치게 하다","ex":"…ow that any objections THERE had material weight with Mr. Darcy, whose pride, she was convinced, would receive a deeper wound from the want of importance in his friend's connections, than from their want of sense; and she was quite decided, at l…","ex_ch":33,"syn":["hurt","spite","offend"],"ipa":"ˈwuːnd","o":1556},{"w":"wounded","pos":"adj","ch":24,"s":"…inion of him must be materially affected by the difference, her sister's situation remained the same, her peace equally wounded.","x":1,"en":"suffering from physical injury especially that suffered in battle","ko":"상처 입은","ex":"If I have wounded your sister's feelings, it was unknowingly done and though the motives which governed me may to you very naturally appear insufficient, I have not yet learnt to condemn them.","ex_ch":35,"syn":["hurt"],"ipa":"ˈwuːndɪd","o":1557}]</script>
<script>
const DATA = JSON.parse(document.getElementById('vocabData').textContent);
const N = DATA.length;
const LS = {
  pos:'pnpv_pos', know:'pnpv_know', again:'pnpv_again',
  shuf:'pnpv_shuf', order:'pnpv_order', qmark:'pnpv_qmark', ch:'pnpv_ch', ext:'pnpv_ext'
};
function lget(k,d){ try{const v=localStorage.getItem(k); return v==null?d:JSON.parse(v);}catch(e){return d;} }
function lset(k,v){ try{localStorage.setItem(k,JSON.stringify(v));}catch(e){} }

let know = new Set(lget(LS.know,[]));
let again = new Set(lget(LS.again,[]));
let pos = lget(LS.pos,null);  // DATA index of current card (stable across filters)
let shuf = lget(LS.shuf,false);
let order = lget(LS.order,null);
let qmark = lget(LS.qmark,0);
let chFilter = lget(LS.ch,0); // 0 = all
let ext = lget(LS.ext,true);  // include 보강 words
let lvl = 0; // hint level
const BOOK = [...Array(N).keys()].sort((a,b)=>(DATA[a].o??a)-(DATA[b].o??b));

function saveSets(){ lset(LS.know,[...know]); lset(LS.again,[...again]); updateCounts(); }
function esc(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

/* ---------- British pronunciation (TTS) ---------- */
let gbVoice=null;
function pickVoice(){
  const vs=speechSynthesis.getVoices();
  gbVoice = vs.find(v=>/en[-_]GB/i.test(v.lang)&&/sonia|libby|hazel|kate|susan|serena|stephanie|martha/i.test(v.name))
         || vs.find(v=>/en[-_]GB/i.test(v.lang))
         || vs.find(v=>/^en/i.test(v.lang)) || null;
}
if('speechSynthesis' in window){ pickVoice(); speechSynthesis.onvoiceschanged=pickVoice; }
function speak(text){
  if(!('speechSynthesis' in window)) return;
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text.replace(/…/g,' '));
  u.lang='en-GB'; if(gbVoice) u.voice=gbVoice; u.rate=0.92;
  speechSynthesis.speak(u);
}
document.addEventListener('click',ev=>{
  const b=ev.target.closest('button.spk');
  if(b){ ev.stopPropagation(); speak(b.dataset.say); }
},true);

function hiWord(text,e){
  const target = e.f || e.w.split(' ')[0].replace(/\s*\(.*\)/,'');
  const stem = target.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
  const rx = new RegExp('\\b('+stem+'\\w*)','i');
  const m = text.match(rx);
  if(m){ return esc(text.slice(0,m.index)) + '<b>' + esc(m[0]) + '</b>' + esc(text.slice(m.index+m[0].length)); }
  return esc(text);
}

/* ---------- deck order ---------- */
function baseOrder(){
  let idx = BOOK.slice();
  if(!ext) idx = idx.filter(i=>!DATA[i].x);
  if(chFilter>0) idx = idx.filter(i=>DATA[i].ch===chFilter);
  return idx;
}
function deckOrder(){
  let idx = baseOrder();
  if(shuf && order && order.length){
    const set = new Set(idx);
    idx = order.filter(i=>set.has(i));
  }
  return idx;
}
function reshuffle(){
  order = [...Array(N).keys()];
  for(let i=order.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [order[i],order[j]]=[order[j],order[i]]; }
  lset(LS.order,order);
}

/* ---------- views ---------- */
let view='study';
document.getElementById('nav').addEventListener('click',e=>{
  const b=e.target.closest('button'); if(!b) return;
  setView(b.dataset.v);
});
function setView(v){
  view=v;
  document.querySelectorAll('nav button').forEach(b=>b.classList.toggle('on',b.dataset.v===v));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  document.getElementById('p-'+v).classList.add('on');
  if(v==='study') renderStudy();
  if(v==='list') renderList();
  if(v==='again'){ subLvl=0; renderSub('again'); }
  if(v==='know'){ subLvl=0; renderSub('know'); }
  if(v==='quiz') renderQuizHome();
}
function updateCounts(){
  document.getElementById('cAgain').textContent = again.size? '('+again.size+')':'';
  document.getElementById('cKnow').textContent = know.size? '('+know.size+')':'';
}

/* ---------- staged card ----------
   level 0: word + original sentence
   level 1: + easy example   (skipped when none)
   level 2: + English def & synonyms
   level 3: + Korean meaning                       */
function maxLvl(e){ return e.ex ? 3 : 2; }
function cardHTML(e, level, statusBadge){
  const hasEx = !!e.ex;
  const showEx  = hasEx && level>=1;
  const showEn  = level >= (hasEx?2:1);
  const showKo  = level >= (hasEx?3:2);
  let inner = '<div class="tag">Ch. '+e.ch+(e.x?' · 보강':'')+'</div>'
    + '<div class="box">'+(e.pos?'<i>'+esc(e.pos)+'</i>':'')+'</div>'
    + '<div class="word">'+esc(e.w)+'</div>'
    + (e.ipa? '<div class="ipa">/'+esc(e.ipa)+'/ <button class="spk" data-say="'+esc(e.w.split(' (')[0])+'" title="발음 듣기 (P)">🔊</button></div>' : '')
    + '<div class="sent">'+hiWord(e.s,e)+' <button class="spk sm" data-say="'+esc(e.s).replace(/"/g,'&quot;')+'" title="문장 듣기">🔊</button></div>';
  if(showEx){
    const exl = e.ex_ch? '힌트 · 다른 문장 (Ch. '+e.ex_ch+')' : '힌트 · 예문';
    inner += '<div class="exm"><span class="exl">'+exl+'</span>'+hiWord(e.ex,e)+'</div>';
  }
  if(showEn){
    inner += '<div class="def"><span class="dl">ENGLISH</span>'+esc(e.en)+'</div>';
    if(e.syn && e.syn.length) inner += '<div class="syn">비슷한 말 · <i>'+e.syn.map(esc).join(', ')+'</i></div>';
  }
  if(showKo) inner += '<div class="kr">'+esc(e.ko)+'</div>';
  if(statusBadge==='know') inner += '<div class="stamp know">알아요 ✓</div>';
  if(statusBadge==='again') inner += '<div class="stamp again">또볼래요 ↻</div>';
  const hint = showKo ? 'Space 알아요 · → 또볼래요' : '탭/→ 뭘까요 · Space 알아요';
  inner += '<div class="hint">'+hint+'</div>';
  return '<div class="fcard" id="theCard">'+inner+'</div>';
}

/* ---------- study ---------- */
function statusOf(i){ return know.has(i)?'know': again.has(i)?'again': null; }

function renderQuizBanner(){
  const el=document.getElementById('quizBanner');
  const th = Math.floor(again.size/20)*20;
  if(again.size>=20 && th>qmark){
    el.innerHTML = '<div class="banner"><span class="bt">또볼래요가 '+again.size+'개 쌓였어요! 또볼까퀴즈 한 판 어때요?</span>'
      +'<button id="goQuiz">퀴즈 보기</button><button class="bx" id="dismissQ">나중에</button></div>';
    document.getElementById('goQuiz').onclick=()=>{ qmark=th; lset(LS.qmark,qmark); setView('quiz'); startQuiz(); };
    document.getElementById('dismissQ').onclick=()=>{ qmark=th; lset(LS.qmark,qmark); el.innerHTML=''; };
  } else el.innerHTML='';
}

function renderStudy(){
  renderQuizBanner();
  const sel=document.getElementById('chSel');
  if(!sel.dataset.done){
    let o='<option value="0">전체 챕터</option>';
    const chs=[...new Set(DATA.map(e=>e.ch))].sort((a,b)=>a-b);
    chs.forEach(c=>o+='<option value="'+c+'">Chapter '+c+'</option>');
    sel.innerHTML=o; sel.dataset.done=1;
    sel.onchange=()=>{ chFilter=+sel.value; lset(LS.ch,chFilter); pos=0; lset(LS.pos,pos); lvl=0; renderStudy(); };
  }
  sel.value=chFilter;
  const xb=document.getElementById('extBtn');
  xb.classList.toggle('on',ext);
  xb.onclick=()=>{ ext=!ext; lset(LS.ext,ext); lvl=0; renderStudy(); };
  const sb=document.getElementById('shufBtn');
  sb.classList.toggle('on',shuf);
  sb.onclick=()=>{ shuf=!shuf; lset(LS.shuf,shuf); if(shuf) reshuffle(); pos=null; lset(LS.pos,pos); lvl=0; renderStudy(); };

  const idx = deckOrder();
  const box=document.getElementById('studyCard');
  if(!idx.length){ box.innerHTML='<div class="empty"><div class="big">No cards</div>이 챕터에는 카드가 없어요.</div>'; return; }
  let p = idx.indexOf(pos);
  if(p<0){ p=0; pos=idx[0]; lset(LS.pos,pos); }
  const i=idx[p], e=DATA[i];
  const done = idx.filter(j=>statusOf(j)).length;
  document.getElementById('studyCount').textContent = (p+1)+' / '+idx.length+' · 완료 '+done;

  const atEnd = lvl>=maxLvl(e);
  const btns = atEnd
    ? '<button class="b-again">또볼래요 <small>(→)</small></button><button class="b-know">알아요 <small>(Space)</small></button>'
    : '<button class="b-what">뭘까요 <small>(→)</small></button><button class="b-know">알아요 <small>(Space)</small></button>';
  box.innerHTML = cardHTML(e, lvl, statusOf(i))
    + '<div class="fbtns">'+btns+'</div>'
    + '<div class="fmeta"><div class="navbtns"><button id="prevB">← 이전</button><button id="nextB">다음 →</button></div>'
    + '<span>'+(know.size+' 알아요 · '+again.size+' 또볼래요')+'</span></div>';

  document.getElementById('theCard').onclick=()=>hintOrAgain(false);
  const wb=box.querySelector('.b-what'); if(wb) wb.onclick=()=>hintOrAgain(true);
  const ab=box.querySelector('.b-again'); if(ab) ab.onclick=()=>mark(i,'again');
  box.querySelector('.b-know').onclick=()=>mark(i,'know');
  document.getElementById('prevB').onclick=()=>{ const q=deckOrder(), pp=q.indexOf(pos); if(pp>0){pos=q[pp-1]; lset(LS.pos,pos); lvl=0; renderStudy();} };
  document.getElementById('nextB').onclick=()=>next(idx);
}
/* 뭘까요: reveal next hint; at the end (via key/→) it becomes 또볼래요 */
function curIdx(){ const q=deckOrder(); let pp=q.indexOf(pos); if(pp<0) pp=0; return q[pp]; }
function hintOrAgain(allowAgain){
  const q=deckOrder(); if(!q.length) return;
  const i=curIdx(), e=DATA[i];
  if(lvl<maxLvl(e)){ lvl++; renderStudy(); }
  else if(allowAgain) mark(i,'again');
}
function next(idx){
  const pp=idx.indexOf(pos);
  if(pp<idx.length-1 && pp>=0){ pos=idx[pp+1]; lset(LS.pos,pos); lvl=0; renderStudy(); }
  else if(pp<0 && idx.length){ pos=idx[0]; lset(LS.pos,pos); lvl=0; renderStudy(); }
  else {
    document.getElementById('studyCard').innerHTML =
      '<div class="donecard"><div class="big">The End — for now!</div><div class="note">이 덱의 마지막 카드까지 봤어요. 또볼래요 '+again.size+'개 · 알아요 '+know.size+'개</div></div>';
    document.getElementById('studyCount').textContent = idx.length+' / '+idx.length;
  }
}
function mark(i,what){
  if(what==='know'){ know.add(i); again.delete(i); }
  else { again.add(i); know.delete(i); }
  saveSets();
  renderQuizBanner();
  next(deckOrder());
}

/* ---------- keyboard ---------- */
document.addEventListener('keydown',ev=>{
  if(ev.target.tagName==='INPUT'||ev.target.tagName==='SELECT') return;
  if(view==='study'){
    const q=deckOrder(); if(!q.length) return;
    const i=curIdx();
    if(ev.code==='Space'){ ev.preventDefault(); mark(i,'know'); }
    else if(ev.key==='p'||ev.key==='P'){ speak(DATA[i].w.split(' (')[0]); }
    else if(ev.key==='ArrowRight'){ hintOrAgain(true); }
    else if(ev.key==='2'){ mark(i,'again'); }
    else if(ev.key==='1'){ mark(i,'know'); }
    else if(ev.key==='ArrowLeft'){ const pp=q.indexOf(pos); if(pp>0){pos=q[pp-1]; lset(LS.pos,pos); lvl=0; renderStudy();} }
  } else if(view==='again'||view==='know'){
    if(ev.key==='p'||ev.key==='P'){ const l=subList(view); if(l.length) speak(DATA[l[subPos[view]]].w.split(' (')[0]); return; }
    if(ev.code==='Space'){ ev.preventDefault(); view==='again'? subMark('know') : subNext(1); }
    else if(ev.key==='ArrowRight'){ subHint(); }
    else if(ev.key==='ArrowLeft'){ subNext(-1); }
    else if(ev.key==='1'){ subMark('know'); }
    else if(ev.key==='2'){ subMark('again'); }
  }
});

/* ---------- sub decks (again / know) ---------- */
let subPos={again:0,know:0}, subLvl=0;
function subList(kind){ const s=(kind==='again')?again:know; return [...s].sort((a,b)=>(DATA[a].o??a)-(DATA[b].o??b)); }
function renderSub(kind){
  const lst=subList(kind);
  const box=document.getElementById(kind+'Card');
  const cnt=document.getElementById(kind+'Count');
  if(!lst.length){
    box.innerHTML='<div class="empty"><div class="big">Empty</div>아직 카드가 없어요. 학습에서 표시하면 여기에 모여요.</div>';
    cnt.textContent='0장'; return;
  }
  if(subPos[kind]>=lst.length) subPos[kind]=lst.length-1;
  const i=lst[subPos[kind]], e=DATA[i];
  cnt.textContent=(subPos[kind]+1)+' / '+lst.length+'장';
  const atEnd = subLvl>=maxLvl(e);
  let btns='';
  if(!atEnd) btns+='<button class="b-what">뭘까요 <small>(→)</small></button>';
  btns += kind==='again'
    ? '<button class="b-know">알아요로 이동 <small>(Space)</small></button>'
    : '<button class="b-again">또볼래요로 이동 <small>(2)</small></button>';
  box.innerHTML = cardHTML(e, subLvl, kind)
    + '<div class="fbtns">'+btns+'</div>'
    + '<div class="fmeta"><div class="navbtns"><button id="sPrev">← 이전</button><button id="sNext">다음 →</button></div>'
    + '<span class="note">→ 뭘까요 · 끝나면 다음 카드</span></div>';
  document.getElementById('theCard').onclick=()=>subHint();
  const wb=box.querySelector('.b-what'); if(wb) wb.onclick=()=>subHint();
  const kb=box.querySelector('.b-know'); if(kb) kb.onclick=()=>subMark('know');
  const ab=box.querySelector('.b-again'); if(ab) ab.onclick=()=>subMark('again');
  document.getElementById('sPrev').onclick=()=>subNext(-1);
  document.getElementById('sNext').onclick=()=>subNext(1);
}
function subHint(){
  const lst=subList(view); if(!lst.length) return;
  const e=DATA[lst[subPos[view]]];
  if(subLvl<maxLvl(e)){ subLvl++; renderSub(view); }
  else subNext(1);
}
function subNext(d){
  const lst=subList(view); if(!lst.length) return;
  subPos[view]=Math.min(Math.max(subPos[view]+d,0),lst.length-1);
  subLvl=0; renderSub(view);
}
function subMark(target){
  const lst=subList(view); if(!lst.length) return;
  const i=lst[subPos[view]];
  if(target==='know'){ know.add(i); again.delete(i); }
  else { again.add(i); know.delete(i); }
  saveSets();
  subLvl=0; renderSub(view);
}

/* ---------- list ---------- */
let showEn = lget('pnpv_len2', false), showKo = lget('pnpv_lko2', false);
function renderList(){
  const sel=document.getElementById('chSelL');
  if(!sel.dataset.done){
    let o='<option value="0">전체 챕터</option>';
    const chs=[...new Set(DATA.map(e=>e.ch))].sort((a,b)=>a-b);
    chs.forEach(c=>o+='<option value="'+c+'">Chapter '+c+'</option>');
    sel.innerHTML=o; sel.dataset.done=1;
    sel.onchange=renderList;
    document.getElementById('stSel').onchange=renderList;
    document.getElementById('q').oninput=renderList;
    document.getElementById('printBtn').onclick=()=>window.print();
    document.getElementById('enBtn').onclick=()=>{ showEn=!showEn; lset('pnpv_len2',showEn); renderList(); };
    document.getElementById('koBtn').onclick=()=>{ showKo=!showKo; lset('pnpv_lko2',showKo); renderList(); };
  }
  document.getElementById('enBtn').classList.toggle('on',showEn);
  document.getElementById('koBtn').classList.toggle('on',showKo);
  const ch=+sel.value, st=document.getElementById('stSel').value;
  const q=document.getElementById('q').value.trim().toLowerCase();
  let rows=[];
  for(const i of BOOK){
    const e=DATA[i];
    if(!ext && e.x) continue;
    if(ch>0&&e.ch!==ch) continue;
    const s=statusOf(i)||'new';
    if(st!=='all'&&s!==st) continue;
    if(q && !(e.w.toLowerCase().includes(q)||e.ko.toLowerCase().includes(q)||e.en.toLowerCase().includes(q))) continue;
    rows.push(i);
  }
  document.getElementById('listCount').textContent=rows.length+'단어';
  const stTxt={all:'전체 상태',new:'미학습',know:'알아요',again:'또볼래요'}[st];
  document.getElementById('printHead').textContent =
    'Pride & Prejudice 단어 목록 · '+(ch>0?'Chapter '+ch:'전체 챕터')+' · '+stTxt+(q?' · 검색: "'+q+'"':'')
    +' · '+rows.length+'단어'+(ext?'':' (보강 제외)')+(!showEn&&!showKo?' · 단어만':!showEn?' · 영어 뜻 숨김':!showKo?' · 한글 뜻 숨김':'');
  let html='', lastCh=0;
  const chCount={};
  rows.forEach(i=>{chCount[DATA[i].ch]=(chCount[DATA[i].ch]||0)+1;});
  rows.forEach(i=>{
    const e=DATA[i];
    if(e.ch!==lastCh){ html+='<div class="chhead">Chapter '+e.ch+'<span class="n">'+chCount[e.ch]+'단어</span></div>'; lastCh=e.ch; }
    const s=statusOf(i);
    html+='<div class="vrow" data-i="'+i+'">'
      +'<div class="vtop"><b>'+esc(e.w)+'</b>'
      +(e.ipa?'<span class="vipa">/'+esc(e.ipa)+'/</span>':'')
      +(e.x?'<span class="st" style="background:var(--wg-pale);color:var(--wg-deep);">보강</span>':'')
      +(s?'<span class="st '+s+'">'+(s==='know'?'알아요':'또볼래요')+'</span>':'')
      +'</div>'
      +(showEn?'<div class="ven">'+esc(e.en)+'</div>':'')
      +(showKo?'<div class="vko">'+esc(e.ko)+'</div>':'')
      +'</div>';
  });
  document.getElementById('listBody').innerHTML = html || '<div class="empty">검색 결과가 없어요.</div>';
  document.getElementById('listBody').onclick=e=>{
    const r=e.target.closest('.vrow'); if(!r) return;
    const i=+r.dataset.i;
    chFilter=0; lset(LS.ch,0); shuf=false; lset(LS.shuf,false);
    if(DATA[i].x && !ext){ ext=true; lset(LS.ext,true); }
    pos=i; lset(LS.pos,pos); lvl=0;
    setView('study');
  };
}

/* ---------- quiz ---------- */
let quiz=null;
function renderQuizHome(){
  const box=document.getElementById('quizBody');
  if(quiz){ renderQuizQ(); return; }
  if(again.size<4){
    box.innerHTML='<div class="empty"><div class="big">또볼까퀴즈</div>또볼래요 카드가 4장 이상 모이면 퀴즈를 볼 수 있어요.<br>지금 '+again.size+'장 — 학습에서 더 모아 보세요!</div>';
    return;
  }
  box.innerHTML='<div class="empty"><div class="big">또볼까퀴즈</div>'
    +'한글 뜻을 보고 맞는 영어 단어를 골라요.<br>또볼래요 '+again.size+'장에서 최대 20문제를 뽑아요.<br><br>'
    +'<button class="qnext" style="max-width:280px" id="qStart">퀴즈 시작</button></div>';
  document.getElementById('qStart').onclick=startQuiz;
}
function sample(arr,n){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; }
  return a.slice(0,n);
}
function startQuiz(){
  const pool=[...again];
  if(pool.length<4){ renderQuizHome(); return; }
  const qs=sample(pool,Math.min(20,pool.length));
  quiz={qs, k:0, firstTry:0, answered:false, wrongThis:false};
  renderQuizQ();
}
function renderQuizQ(){
  const box=document.getElementById('quizBody');
  if(quiz.k>=quiz.qs.length){
    box.innerHTML='<div class="donecard"><div class="big">'+quiz.firstTry+' / '+quiz.qs.length+'</div>'
      +'<div class="note">첫 시도에 맞힌 문제예요. 퀴즈를 봐도 또볼래요는 그대로 — 카드를 다시 복습하며 알아요로 옮겨 보세요!</div>'
      +'<div class="fbtns" style="max-width:420px;margin:16px auto 0;">'
      +'<button class="b-again" id="qAgainDeck">또볼래요 복습하기</button>'
      +'<button class="b-know" id="qRetry">한 판 더</button></div></div>';
    document.getElementById('qAgainDeck').onclick=()=>{ quiz=null; setView('again'); };
    document.getElementById('qRetry').onclick=()=>{ quiz=null; startQuiz(); };
    return;
  }
  const i=quiz.qs[quiz.k], e=DATA[i];
  const pool=[...again].filter(j=>j!==i);
  let dis = sample(pool,3);
  if(dis.length<3){
    const extra=sample([...Array(N).keys()].filter(j=>j!==i&&!dis.includes(j)),3-dis.length);
    dis=dis.concat(extra);
  }
  const opts=sample([i,...dis],4);
  quiz.wrongThis=false; quiz.answered=false;
  let html='<div class="qbar"><i style="width:'+(quiz.k/quiz.qs.length*100)+'%"></i></div>'
    +'<div class="quizq"><div class="qno">Question '+(quiz.k+1)+' / '+quiz.qs.length+'</div>'
    +'<div class="qw">'+esc(e.ko)+'</div>';
  opts.forEach(j=>{ html+='<button class="opt" data-j="'+j+'">'+esc(DATA[j].w)+'</button>'; });
  html+='</div><div id="qNextWrap"></div>';
  box.innerHTML=html;
  box.querySelectorAll('.opt').forEach(b=>{
    b.onclick=()=>{
      const j=+b.dataset.j;
      if(j===i){
        if(!quiz.answered){
          if(!quiz.wrongThis) quiz.firstTry++;
          quiz.answered=true;
        }
        b.classList.add('right');
        if(!document.getElementById('qNextB')){
          document.getElementById('qNextWrap').innerHTML='<button class="qnext" id="qNextB">'+(quiz.k+1>=quiz.qs.length?'결과 보기':'다음 문제')+'</button>';
          const nb=document.getElementById('qNextB');
          nb.onclick=()=>{ quiz.k++; renderQuizQ(); };
          nb.focus();
        }
      } else if(!quiz.answered){
        quiz.wrongThis=true;
        b.classList.add('wrong');
      }
    };
  });
}

/* ---------- init ---------- */
updateCounts();
renderStudy();
