<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yena's Parlour · P&amp;P 단어카드</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">
<style>
:root{
  --paper:#F7F6F1; --card:#FFFFFF; --ink:#232A33; --soft:#5A6472;
  --wg:#5B7BA6; --wg-deep:#3E5E8C; --wg-pale:#E9EEF5; --line:#CBD6E4;
  --seal:#95392F; --seal-deep:#7A2C24; --gilt:#A8842C; --gilt-pale:#F5EFDE;
  --ok:#4C7A5A;
  --en:'Libre Baskerville', Georgia, serif;
  --ko:'Pretendard Variable',Pretendard,'Noto Sans KR',-apple-system,sans-serif;
  --sans:'Pretendard Variable',Pretendard,'Noto Sans KR',-apple-system,sans-serif;
}
*{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
body{margin:0; background:var(--paper); color:var(--ink); font-family:var(--sans); font-size:15.5px; line-height:1.7;}
.wrap{max-width:760px; margin:0 auto; padding:0 16px 100px;}
header{padding:24px 0 8px; text-align:center;}
.eb{font-size:12px; letter-spacing:.22em; color:var(--wg-deep); text-transform:uppercase;}
h1{font-family:var(--en); font-weight:400; font-size:clamp(25px,6vw,36px); margin:5px 0 2px;}
.sub{font-family:var(--sans); color:var(--soft); font-size:14.5px; margin-bottom:12px;}
nav{position:sticky; top:0; z-index:30; background:rgba(247,246,241,.95); backdrop-filter:blur(6px); display:flex; gap:6px; padding:10px 0; border-bottom:1px solid var(--line); margin-bottom:16px; overflow-x:auto;}
nav button{flex:1 0 auto; border:1px solid var(--line); background:var(--card); color:var(--soft); padding:8px 14px; border-radius:999px; font-size:14px; font-weight:500; cursor:pointer; white-space:nowrap; font-family:var(--sans);}
nav button.on{background:var(--wg-deep); border-color:var(--wg-deep); color:#fff;}
nav button:focus-visible{outline:2px solid var(--seal); outline-offset:2px;}
nav button .cnt{font-size:12px; opacity:.75; margin-left:3px;}
.panel{display:none;} .panel.on{display:block; animation:fade .22s ease;}
@keyframes fade{from{opacity:0; transform:translateY(4px);} to{opacity:1;}}
@media (prefers-reduced-motion:reduce){.panel.on{animation:none;}}
.note{font-size:14px; color:var(--soft);}

.toolrow{display:flex; gap:8px; align-items:center; margin-bottom:10px; flex-wrap:wrap;}
.tbtn{border:1px solid var(--line); background:#fff; border-radius:9px; padding:8px 13px; font-size:14px; cursor:pointer; color:var(--soft); font-family:var(--sans);}
.tbtn.on{background:var(--ink); color:#fff; border-color:var(--ink);}
.pcount{margin-left:auto; font-size:13.5px; color:var(--soft);}
select.tsel{border:1px solid var(--line); background:#fff; border-radius:9px; padding:8px 10px; font-size:14px; color:var(--soft); font-family:var(--sans);}
.search{width:100%; border:1px solid var(--line); border-radius:999px; padding:10px 16px; font-size:15px; font-family:var(--sans); background:#fff; margin-bottom:10px; color:var(--ink);}
.search:focus{outline:2px solid var(--wg);}

/* flash card */
.fcard{background:var(--card); border:1px solid var(--line); border-radius:14px; min-height:300px; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:44px 24px 38px; cursor:pointer; position:relative; box-shadow:0 1px 0 var(--line);}
.fcard .tag{position:absolute; top:12px; left:14px; font-size:12px; letter-spacing:.13em; color:var(--wg-deep); text-transform:uppercase;}
.fcard .box{position:absolute; top:12px; right:14px; font-size:12px; color:var(--soft);}
.fcard .word{font-family:var(--en); font-size:32px; line-height:1.25;}
.fcard .pos{color:var(--soft); font-style:italic; font-size:13px; margin-bottom:8px;}
.fcard .ipa{font-family:var(--sans); font-size:15px; color:var(--soft); margin-top:2px; display:flex; align-items:center; justify-content:center; gap:7px;}
button.spk{border:1px solid var(--line); background:#fff; color:var(--wg-deep); border-radius:999px; width:28px; height:28px; font-size:14px; line-height:1; cursor:pointer; padding:0; flex:none;}
button.spk:hover{background:var(--wg-pale);}
button.spk.sm{width:23px; height:23px; font-size:11.5px; vertical-align:middle; margin-left:6px;}
.fcard .sent{font-family:var(--en); font-size:15px; line-height:1.65; color:var(--ink); max-width:560px; margin-top:4px;}
.fcard .sent b{color:var(--seal); font-weight:700;}
.fcard .exm{font-family:var(--en); font-size:15.5px; font-style:italic; line-height:1.6; color:var(--ink); max-width:560px; margin-top:12px; padding-top:10px; border-top:1px dashed var(--line);}
.fcard .exm b{color:var(--seal); font-weight:700;}
.fcard .exm .exl{font-family:var(--sans); font-style:normal; font-size:11.5px; letter-spacing:.12em; color:var(--gilt); display:block; margin-bottom:2px;}
.fcard .def{font-size:16.5px; max-width:500px; margin-top:14px; padding-top:12px; border-top:1px solid var(--gilt-pale);}
.fcard .def .dl{font-family:var(--sans); font-size:11.5px; letter-spacing:.12em; color:var(--wg-deep); display:block;}
.fcard .syn{font-size:14px; color:var(--soft); margin-top:6px;}
.fcard .syn i{font-family:var(--en); color:var(--wg-deep); font-style:normal;}
.fcard .kr{font-family:var(--sans); font-weight:600; color:var(--wg-deep); font-size:18.5px; margin-top:10px;}
.fcard .hint{position:absolute; bottom:10px; left:0; right:0; font-size:12px; color:var(--soft);}
.fcard .stamp{position:absolute; bottom:34px; right:16px; font-size:12px; font-weight:700; padding:3px 10px; border-radius:999px;}
.stamp.know{background:#EAF3EC; color:var(--ok);}
.stamp.again{background:var(--gilt-pale); color:var(--gilt);}
.fbtns{display:flex; gap:10px; margin-top:12px;}
.fbtns button{flex:1; padding:13px; border-radius:10px; border:none; font-size:15px; font-weight:700; cursor:pointer; font-family:var(--sans);}
.fbtns button small{font-weight:500; opacity:.75;}
.b-what{background:#fff; border:1.5px solid var(--wg); color:var(--wg-deep);}
.b-again{background:#fff; border:1.5px solid var(--gilt); color:var(--gilt);}
.b-know{background:var(--wg-deep); color:#fff;}
.fmeta{display:flex; justify-content:space-between; font-size:13px; color:var(--soft); margin-top:8px; gap:8px; flex-wrap:wrap;}
.navbtns{display:flex; gap:8px;}
.navbtns button{border:1px solid var(--line); background:#fff; border-radius:8px; padding:3px 12px; cursor:pointer; color:var(--soft); font-size:13px; font-family:var(--sans);}
.keyhelp{font-size:12.5px; color:var(--soft); text-align:center; margin-top:10px;}
.keyhelp kbd{background:#fff; border:1px solid var(--line); border-bottom-width:2px; border-radius:5px; padding:0 6px; font-family:var(--sans); font-size:11.5px;}

.banner{background:var(--gilt-pale); border:1px solid var(--gilt); border-radius:12px; padding:13px 15px; margin:12px 0; display:flex; align-items:center; gap:10px; flex-wrap:wrap;}
.banner .bt{font-weight:700; color:var(--gilt); flex:1;}
.banner button{border:none; background:var(--gilt); color:#fff; border-radius:9px; padding:9px 16px; font-weight:700; cursor:pointer; font-size:14px; font-family:var(--sans);}
.banner .bx{background:none; color:var(--soft); border:none; font-size:13px; padding:6px;}

.donecard{background:var(--card); border:1px solid var(--line); border-radius:14px; padding:40px 24px; text-align:center;}
.donecard .big{font-family:var(--en); font-size:26px; margin-bottom:8px;}

/* list */
.chhead{font-family:var(--en); font-size:14px; letter-spacing:.14em; color:var(--wg-deep); text-transform:uppercase; margin:20px 0 2px; border-bottom:1px solid var(--line); padding-bottom:4px;}
.chhead .n{color:var(--soft); font-family:var(--sans); letter-spacing:0; text-transform:none; font-size:12.5px; float:right;}
.vrow{padding:10px 4px 9px; border-bottom:1px dashed var(--line); font-size:14.5px; cursor:pointer;}
.vrow:hover{background:var(--wg-pale);}
.vrow .vtop{display:flex; gap:9px; align-items:baseline; flex-wrap:wrap;}
.vrow b{font-family:var(--en); font-size:16.5px; white-space:nowrap;}
.vrow .vipa{color:var(--soft); font-size:13.5px;}
.vrow .st{font-size:11.5px; font-weight:700; white-space:nowrap; padding:1px 8px; border-radius:999px;}
.vrow .ven{font-family:var(--en); font-size:13.5px; color:var(--ink); opacity:.85; margin-top:1px; line-height:1.5;}
.vrow .vko{font-size:13.5px; font-weight:600; color:var(--wg-deep); margin-top:1px;}
.st.know{background:#EAF3EC; color:var(--ok);}
.st.again{background:var(--gilt-pale); color:var(--gilt);}
#printHead{display:none;}
@media print{
  body{background:#fff; font-size:12px;}
  nav, header .sub, .toolrow, .search, footer, .keyhelp, #quizBanner{display:none !important;}
  .wrap{max-width:none; padding:0;}
  header{padding:0 0 4px; text-align:left;}
  h1{font-size:19px; margin:0;}
  .eb{display:none;}
  #printHead{display:block; font-size:11.5px; color:#555; margin:2px 0 8px;}
  #p-study .fcard, #p-study .fbtns, #p-study .fmeta, #studyCard{display:none !important;}
  .vrow{break-inside:avoid; page-break-inside:avoid; padding:6px 0 5px; cursor:auto;}
  .vrow b{font-size:13.5px;}
  .vrow .vipa{font-size:11.5px;}
  .vrow .ven{font-size:11px; opacity:1;}
  .vrow .vko{font-size:11.5px;}
  .chhead{margin:12px 0 1px; font-size:11.5px;}
  .st{border:1px solid #bbb;}
}

/* quiz */
.quizq{background:var(--card); border:1px solid var(--line); border-radius:12px; padding:18px 16px;}
.quizq .qno{font-size:12px; letter-spacing:.13em; color:var(--wg-deep); text-transform:uppercase; margin-bottom:6px;}
.quizq .qw{font-family:var(--sans); font-weight:700; font-size:20px; margin-bottom:12px; color:var(--ink); line-height:1.5;}
.quizq button.opt{display:block; width:100%; text-align:left; margin:6px 0; padding:12px 14px; border-radius:9px; border:1px solid var(--line); background:#fff; font-size:16px; cursor:pointer; font-family:var(--en);}
.quizq button.opt.right{background:#EAF3EC; border-color:var(--ok);}
.quizq button.opt.wrong{background:#F6E8E6; border-color:var(--seal); color:var(--seal);}
.qnext{margin-top:12px; width:100%; padding:12px; border:none; border-radius:10px; background:var(--wg-deep); color:#fff; font-weight:700; font-size:15px; cursor:pointer; font-family:var(--sans);}
.qbar{height:6px; background:var(--wg-pale); border-radius:999px; margin-bottom:14px; overflow:hidden;}
.qbar i{display:block; height:100%; background:var(--wg-deep); border-radius:999px; transition:width .25s;}
.empty{padding:48px 16px; text-align:center; color:var(--soft);}
.empty .big{font-family:var(--en); font-size:22px; color:var(--ink); margin-bottom:6px;}
footer{margin-top:36px; text-align:center; color:var(--soft); font-size:12.5px;}
@media (max-width:480px){
  .fcard{padding:42px 16px 36px; min-height:280px;}
  .fcard .word{font-size:27px;}
  .fcard .sent{font-size:14px;}
  .fcard .exm{font-size:14.5px;}
}
</style>
</head>
<body>
<div class="wrap">
<header>
  <div class="eb">Yena's Parlour</div>
  <h1>Pride &amp; Prejudice 단어카드</h1>
  <div class="sub">원문 등장 순서대로 · 기본 2,001 + 보강 645 단어 · 61챕터</div>
</header>

<nav id="nav">
  <button data-v="study" class="on">학습</button>
  <button data-v="list">목록</button>
  <button data-v="again">또볼래요 <span class="cnt" id="cAgain"></span></button>
  <button data-v="know">알아요 <span class="cnt" id="cKnow"></span></button>
  <button data-v="quiz">또볼까퀴즈</button>
</nav>

<!-- 학습 -->
<section class="panel on" id="p-study">
  <div id="quizBanner"></div>
  <div class="toolrow">
    <select class="tsel" id="chSel"></select>
    <button class="tbtn" id="extBtn" title="빈도 한 단계 위(더 쉬운) 보강 단어 645개 포함/제외">보강 단어</button>
    <button class="tbtn" id="shufBtn">셔플</button>
    <span class="pcount" id="studyCount"></span>
  </div>
  <div id="studyCard"></div>
  <div class="keyhelp"><kbd>→</kbd> 뭘까요(힌트) · <kbd>Space</kbd> 알아요 · <kbd>2</kbd> 또볼래요 · <kbd>P</kbd> 발음 · <kbd>←</kbd> 이전</div>
</section>

<!-- 목록 -->
<section class="panel" id="p-list">
  <div id="printHead"></div>
  <input class="search" id="q" placeholder="단어나 뜻으로 검색…">
  <div class="toolrow">
    <select class="tsel" id="chSelL"></select>
    <select class="tsel" id="stSel">
      <option value="all">전체 상태</option>
      <option value="new">미학습</option>
      <option value="know">알아요</option>
      <option value="again">또볼래요</option>
    </select>
    <button class="tbtn" id="enBtn">영어 뜻</button>
    <button class="tbtn" id="koBtn">한글 뜻</button>
    <button class="tbtn" id="printBtn">인쇄 / PDF</button>
    <span class="pcount" id="listCount"></span>
  </div>
  <div id="listBody"></div>
</section>

<!-- 또볼래요 -->
<section class="panel" id="p-again">
  <div class="note" style="margin-bottom:10px;">또볼래요로 표시한 카드예요. 다시 보고 <b>알아요</b>로 옮길 수 있어요.</div>
  <div class="toolrow"><span class="pcount" id="againCount"></span></div>
  <div id="againCard"></div>
</section>

<!-- 알아요 -->
<section class="panel" id="p-know">
  <div class="note" style="margin-bottom:10px;">알아요로 표시한 카드예요. 다시 헷갈리면 <b>또볼래요</b>로 되돌릴 수 있어요.</div>
  <div class="toolrow"><span class="pcount" id="knowCount"></span></div>
  <div id="knowCard"></div>
</section>

<!-- 퀴즈 -->
<section class="panel" id="p-quiz">
  <div id="quizBody"></div>
</section>

<footer>Jane Austen, <i>Pride and Prejudice</i> (1813) · 예나의 응접실</footer>
</div>

