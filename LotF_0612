function renderChapter(i){
  onIntro = false;
  document.body.classList.remove('introview');
  cur = i;
  const c = CH[i];
  const hint = document.querySelector('main .hint'); if(hint) hint.style.display = '';
  document.getElementById('chnum').textContent = 'Chapter ' + c.num;
  document.getElementById('chttl').textContent = c.title;
  document.getElementById('chsel').value = i;
  document.getElementById('prog').textContent = (c.num) + ' / 12';
  document.getElementById('prev').disabled = false;
  document.getElementById('next').disabled = (i===CH.length-1);

  let html = '';
  c.paras.forEach((p, idx)=>{
    const isDia = /^[“"]/.test(p.trim());
    const cls = (idx===0 ? 'lead' : '') + (isDia ? ' dialogue':'');
    const escP = p.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    // tokenize words vs non-words; preserve everything
    const out = escP.replace(/([A-Za-z]+(?:['\-][A-Za-z]+)*)/g, function(m){
      const clean = m.replace(/&#39;/g,"'");
      const g = glossLookup(clean);
      const cl = 'w' + (g?' g':'');
      return '<span class="'+cl+'">'+m+'</span>';
    });
    html += '<p class="'+cls.trim()+'" data-p="'+idx+'" data-ctx="'+p.replace(/"/g,'&quot;').replace(/'/g,'&#39;')+'">'+out+'</p>';
    html += '<div class="tr pending" data-tr="'+idx+'"><span class="tr-text">…</span><button class="tr-polish" type="button" title="자연스러운 한국어로 다듬기" aria-label="다듬기">✎</button><button class="tr-redo" type="button" title="문맥에 맞게 다시 번역" aria-label="다시 번역">↻</button></div>';
  });
  reader.innerHTML = html;
  markSaved();
  applyMarks();
  applyTranslations(i);
  if(document.body.classList.contains('showtr')) activateTranslation(i);
  window.scrollTo(0,0);
}

function markSaved(){
