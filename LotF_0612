<script>
/* ============ merged-shell glue (runs after the reader script) ============ */
(function(){
  const body = document.body;

  /* keep header height in a CSS var so the analyze view fills exactly the rest */
  const hdr = document.querySelector('header');
  function measureHdr(){ document.documentElement.style.setProperty('--hdr',(hdr?hdr.offsetHeight:56)+'px'); }
  measureHdr(); window.addEventListener('resize', measureHdr);

  /* brand subtitle gets a mode pill */
  const brand = document.querySelector('.brand');
  if(brand){ const pill=document.createElement('span'); pill.className='modepill'; pill.textContent='✱ 분석 모드'; brand.appendChild(pill); }

  /* ---- build the analysis app in a same-origin iframe (Blob URL) ---- */
  const b64 = document.getElementById('analysisB64').textContent.trim();
  const bytes = Uint8Array.from(atob(b64), c=>c.charCodeAt(0));
  const html  = new TextDecoder('utf-8').decode(bytes);
  const blobURL = URL.createObjectURL(new Blob([html], {type:'text/html'}));
  const afr = document.getElementById('afr');

  let afrLoaded = false;
  const afrReady = new Promise(res=>{
    afr.addEventListener('load', ()=>{
      afrLoaded = true;
      try{
        /* give the embedded app access to Claude's persistent storage (same-origin),
           then have it reload saved analysis answers from there */
        if(window.storage) afr.contentWindow.storage = window.storage;
        if(typeof afr.contentWindow.__reloadDB === 'function') afr.contentWindow.__reloadDB();
      }catch(e){}
      res();
    }, {once:true});
  });
  afr.src = blobURL;  /* load eagerly so it's ready by the time the reader finishes a chapter */

  async function syncAnalyze(i){
    await afrReady;
    /* primary, origin-proof path: postMessage */
    try{
      afr.contentWindow.postMessage(
        {type:'lotf-sync', chapter:CH[i].num, paras:CH[i].paras}, '*');
    }catch(e){}
    /* best-effort direct call too (works when same-origin) */
    try{
      const w = afr.contentWindow;
      w.LOTF_PARAS = CH[i].paras;
      if(typeof w.showView === 'function') w.showView(String(CH[i].num));
      w.scrollTo(0,0);
    }catch(e){}
  }

  /* ---- mode transitions ---- */
  function enterAnalyze(i){
    if(onIntro) return;                       /* no analysis for the intro page */
    body.classList.remove('mode-read');
    body.classList.add('mode-analyze');
    document.getElementById('anaTitle').textContent = CH[i].num + '장 분석 · ' + CH[i].title;
    document.getElementById('anaProg').textContent = CH[i].num + '장 분석';
    document.getElementById('backReadLabel').textContent = '이전';
    const last = (i === CH.length-1);
    const nb = document.getElementById('nextRead');
    nb.disabled = last;
    document.getElementById('nextReadLabel').textContent = '다음';
    measureHdr();
    syncAnalyze(i);
    window.scrollTo(0,0);
  }
  function enterRead(i){
    body.classList.remove('mode-analyze');
    body.classList.add('mode-read');
    if(typeof i === 'number' && i !== cur){ renderChapter(i); }
    window.scrollTo(0,0);
  }
  /* expose for any inline use */
  window.enterAnalyze = enterAnalyze; window.enterRead = enterRead;

  /* ---- reflect chapter state into the CTA; wrap reader's renderers ---- */
  function refreshCTA(){
    body.classList.toggle('on-chapter', !onIntro);
    if(!onIntro){
      const btn = document.getElementById('toAnalyzeBtn');
      if(btn) btn.textContent = '✍️ ' + CH[cur].num + '장 분석하기';
    }
  }
  const _renderChapter = renderChapter;
  renderChapter = function(i){ _renderChapter(i); refreshCTA(); };
  const _renderIntro = renderIntro;
  renderIntro = function(){ _renderIntro(); body.classList.remove('on-chapter'); };

  /* ---- wire the buttons ---- */
  document.getElementById('toAnalyzeBtn').addEventListener('click', ()=> enterAnalyze(cur));
  document.getElementById('backRead').addEventListener('click', ()=> enterRead(cur));
  document.getElementById('nextRead').addEventListener('click', ()=>{
    if(cur < CH.length-1) enterRead(cur+1);
  });

  /* ---- chapter dropdown: in analyze mode, switching chapters stays in analyze ---- */
  const sel = document.getElementById('chsel');
  sel.addEventListener('change', ()=>{
    if(!body.classList.contains('mode-analyze')) return;   /* read-mode handled by reader */
    const v = sel.value;
    if(v === 'intro'){ enterRead(); /* intro -> drop to reading */ }
    else { enterAnalyze(+v); }
  });

  /* ---- #1 resume reading: persist last chapter + exact paragraph; offer resume on intro ---- */
  async function readProgress(){ try{ const r=await store.get('lotf_progress'); return r&&r.value?JSON.parse(r.value):null; }catch(e){ return null; } }
  function writeProgress(p){ try{ store.set('lotf_progress', JSON.stringify(p)); }catch(e){} }

  function headOffset(){ const h=document.querySelector('header'); return (h?h.offsetHeight:56) + 10; }
  /* which paragraph sits at the top of the viewport, and how far we're into it */
  function readAnchor(){
    const rd=document.getElementById('reader');
    const ps=rd?rd.querySelectorAll('p[data-p]'):[];
    const top=headOffset();
    for(let k=0;k<ps.length;k++){
      const r=ps[k].getBoundingClientRect();
      if(r.bottom>top){
        const f=r.height>0 ? (top-r.top)/r.height : 0;
        return {p:+ps[k].dataset.p, f:Math.max(0,Math.min(1,f))};
      }
    }
    return {p:0,f:0};
  }
  /* scroll so paragraph p (offset f into it) lands just under the header */
  function scrollToAnchor(p,f){
    const rd=document.getElementById('reader');
    const el=rd?rd.querySelector('p[data-p="'+p+'"]'):null;
    if(!el) return false;
    const r=el.getBoundingClientRect();
    const y=window.scrollY + r.top - headOffset() + (f||0)*r.height;
    window.scrollTo(0, Math.max(0,y));
    return true;
  }

  let scrollT;
  window.addEventListener('scroll', ()=>{
    if(onIntro || !body.classList.contains('mode-read')) return;
    clearTimeout(scrollT);
    scrollT = setTimeout(()=>{ const a=readAnchor(); writeProgress({ch:cur, p:a.p, f:a.f, y:window.scrollY, ts:Date.now()}); }, 350);
  }, {passive:true});
  const _rcP = renderChapter;
  renderChapter = function(i){ _rcP(i); writeProgress({ch:i, p:0, f:0, y:0, ts:Date.now()}); };
  async function refreshResume(){
    const p = await readProgress();
    if(onIntro && p && typeof p.ch==='number' && CH[p.ch]){
      body.classList.add('has-progress');
      const t = document.getElementById('resumeText');
      if(t) t.innerHTML = '지난번에 <b>'+CH[p.ch].num+'장 · '+CH[p.ch].title+'</b>까지 읽으셨어요.';
    } else { body.classList.remove('has-progress'); }
  }
  const _riP = renderIntro;
  renderIntro = function(){ _riP(); refreshResume(); };

  /* restore the saved spot, retrying across frames so late font/layout reflow can't strand us */
  function restoreSpot(p){
    const hasAnchor = (typeof p.p === 'number');
    const go = ()=>{ if(hasAnchor){ if(!scrollToAnchor(p.p, p.f||0) && p.y) window.scrollTo(0,p.y); }
                     else if(p.y) window.scrollTo(0,p.y); };
    requestAnimationFrame(go);
    [80,250,500,900,1400].forEach(function(t){ setTimeout(go, t); });
    if(document.fonts && document.fonts.ready) document.fonts.ready.then(function(){ setTimeout(go,30); });
  }
  const resumeBtn = document.getElementById('resumeBtn');
  if(resumeBtn) resumeBtn.addEventListener('click', async ()=>{
    const p = await readProgress(); if(!p || !CH[p.ch]) return;
    renderChapter(p.ch);
    restoreSpot(p);
  });

  /* ---- #3 backup: export / import all saved data via the same store the apps use ---- */
  const BK_KEYS = ['lotf_vocab','lotf_marked','lotf_progress','lotf_analysis_v1']
    .concat(Array.from({length:12},(_,i)=>'lotf_tr_'+(i+1)));
  async function collectBackup(){
    const d={};
    for(const k of BK_KEYS){ try{ const r=await store.get(k); if(r&&r.value!=null) d[k]=r.value; }catch(e){} }
    return d;
  }
  const exBtn=document.getElementById('bkExport');
  if(exBtn) exBtn.addEventListener('click', async ()=>{
    const data = await collectBackup();
    const blob=new Blob([JSON.stringify({_app:'lotf', _ts:Date.now(), data:data},null,2)],
      {type:'application/json'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
    a.download='lotf-backup.json'; document.body.appendChild(a); a.click();
    setTimeout(()=>{ URL.revokeObjectURL(a.href); a.remove(); }, 0);
  });
  const imBtn=document.getElementById('bkImport'), imFile=document.getElementById('bkFile');
  if(imBtn && imFile){
    imBtn.addEventListener('click', ()=> imFile.click());
    imFile.addEventListener('change', ()=>{
      const f=imFile.files && imFile.files[0]; if(!f) return;
      const r=new FileReader();
      r.onload=async ()=>{ try{
        const j=JSON.parse(r.result), d=(j && j.data)?j.data:j;
        await Promise.all(Object.keys(d).filter(k=>/^lotf_/.test(k)).map(k=> store.set(k, d[k])));
        alert('불러왔어요. 페이지를 새로고침합니다.'); location.reload();
      }catch(e){ alert('파일을 읽을 수 없어요 — 올바른 백업 파일인지 확인해 주세요.'); } };
      r.readAsText(f);
    });
  }

  /* start in read mode */
  body.classList.add('mode-read');
  refreshCTA();
  refreshResume();
})();
</script>


