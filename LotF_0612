function placeTip(el){
  const r = el.getBoundingClientRect();
  tip.style.display='block';
  const tw = tip.offsetWidth, th = tip.offsetHeight;
  let left = window.scrollX + r.left + r.width/2 - tw/2;
  left = Math.max(10, Math.min(left, window.scrollX + document.documentElement.clientWidth - tw - 10));
  let top = window.scrollY + r.top - th - 12;
  let below = false;
  if(top < window.scrollY + 6){ top = window.scrollY + r.bottom + 12; below = true; }
  tip.style.left = left+'px';
  tip.style.top = top+'px';
  const arrow = tip.querySelector('.arrow');
  const ax = window.scrollX + r.left + r.width/2 - left - 6;
  arrow.style.left = Math.max(12, Math.min(ax, tw-24))+'px';
  arrow.style.top = below ? '-6px' : (th-6)+'px';
}

function buildTip(word, defHtml, src){
  const lw = word.toLowerCase();
  const saved = vocab.some(v=>v.w.toLowerCase()===lw);
  const isMarked = marked.has(lw);
  tipbody.innerHTML =
    '<div class="hw">'+
      '<button class="audio" id="audiobtn" title="영국식 발음 듣기">🔊</button>'+
      '<span class="wtext">'+escapeHtml(word)+'</span>'+
      '<button class="star'+(saved?' on':'')+'" id="starbtn">'+(saved?'★ 저장됨':'★ 저장')+'</button></div>'+
    '<div class="def" id="tipdef">'+defHtml+'</div>'+
    '<div class="foot"><span class="src" id="tipsrc">'+(src||'')+'</span>'+
      (isMarked?'<button class="markbtn" id="markbtn">밑줄 지우기</button>':'')+'</div>';
