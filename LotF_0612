function escapeHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

/* def can be a plain string (curated glossary) or an object {word, phrase, phrase_meaning} (AI) */
function defToHtml(def){
  if(!def) return '';
  if(typeof def === 'string') return '<div class="dword">'+escapeHtml(def)+'</div>';
  let h = '<div class="dword">'+escapeHtml(def.word||'')+'</div>';
  if(def.phrase && def.phrase_meaning){
    h += '<div class="dphrase">'+
         '<span class="plabel">이 문장에선 숙어·구동사</span><br>'+
         '<span class="peng">'+escapeHtml(def.phrase)+'</span>'+
         '<span class="pko">'+escapeHtml(def.phrase_meaning)+'</span></div>';
  }
  return h;
}
function defToText(def){
  if(!def) return '';
  if(typeof def === 'string') return def;
  let t = def.word||'';
  if(def.phrase && def.phrase_meaning) t += '  ·  ['+def.phrase+'] '+def.phrase_meaning;
  return t;
}

/* ---------- British pronunciation (Web Speech API) ---------- */
function pickVoice(){
  const vs = window.speechSynthesis ? speechSynthesis.getVoices() : [];
  if(!vs.length) return null;
  // prefer a real en-GB voice; common names: Daniel, Kate, Serena, Arthur, "Google UK"
  let v = vs.find(x=>/en-GB/i.test(x.lang) && /female|kate|serena|google uk english female/i.test(x.name))
       || vs.find(x=>/en-GB/i.test(x.lang))
       || vs.find(x=>/Daniel|Arthur|Oliver|British|UK/i.test(x.name));
  return v || null;
}
function initVoices(){
  if(!window.speechSynthesis) return;
  gbVoice = pickVoice();
  speechSynthesis.onvoiceschanged = ()=>{ gbVoice = pickVoice(); };
}
function speak(word, btn){
  if(!window.speechSynthesis){ if(btn) btn.textContent='✕'; return; }
  speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(word.replace(/-/g,' ').replace(/[^A-Za-z' ]/g,''));
  u.lang = 'en-GB';
  if(!gbVoice) gbVoice = pickVoice();
  if(gbVoice) u.voice = gbVoice;
  u.rate = 0.9; u.pitch = 1.0;
  if(btn){
    btn.classList.add('playing');
    u.onend = ()=>btn.classList.remove('playing');
    u.onerror = ()=>btn.classList.remove('playing');
  }
  speechSynthesis.speak(u);
}

