  #studyOverlay.on{display:flex;}
  #studyTop{flex:none;display:flex;align-items:center;gap:12px;padding:10px 14px;
    border-bottom:1px solid var(--line,#d9cdb8);background:var(--paper2,#efe5d6);}
  #studyBack{border:1px solid var(--line,#d9cdb8);background:var(--paper,#f4ece0);color:var(--ink,#2b2620);
    font:600 13px "Noto Sans KR";padding:8px 12px;border-radius:9px;cursor:pointer;}
  #studyTopLbl{font:600 13.5px "Noto Sans KR";color:var(--ink-soft,#5c5346);}
  #studyFrame{flex:1 1 auto;width:100%;border:0;}
  #studyFab{position:fixed;right:14px;bottom:16px;z-index:8000;border:0;cursor:pointer;
    background:var(--gold,#b98b2e);color:#fff;font:700 14px "Noto Sans KR";
    padding:12px 16px;border-radius:99px;box-shadow:0 4px 14px rgba(40,30,15,.28);}
  #studyFab:active{transform:translateY(1px);}
  #chapQuizBtn{border:1px solid var(--gold,#b98b2e);background:var(--gold,#b98b2e);color:#fff;
    font:700 14px "Noto Sans KR";padding:11px 16px;border-radius:11px;cursor:pointer;}
</style>
<script>
(function(){
  var loaded=false;
  // derive current chapter number from the chapter <select> (closure-safe)
  window.__lotfChap=function(){
    var sel=document.getElementById('chsel'); if(!sel) return null;
    var v=sel.value; if(v==='intro'||v==='') return null;
    var opt=sel.options[sel.selectedIndex];
    var m=(opt&&opt.textContent||'').match(/^\s*(\d+)/);
    return m?parseInt(m[1],10):null;
  };
  try{ if(localStorage.getItem('lotf_dark')==='1') document.documentElement.classList.add('dark'); }catch(e){}
  var db=document.getElementById('darkToggle'); if(db) db.textContent=document.documentElement.classList.contains('dark')?'☀️':'🌙';
  window.toggleShellDark=function(){
    var on=document.documentElement.classList.toggle('dark');
    try{localStorage.setItem('lotf_dark',on?'1':'0');}catch(e){}
    if(db) db.textContent=on?'☀️':'🌙';
    var fr=document.getElementById('studyFrame');
    try{ if(fr&&fr.contentWindow) fr.contentWindow.postMessage({type:'sync',dark:on},'*'); }catch(e){}
  };
  function isDark(){ return document.documentElement.classList.contains('dark'); }
  window.openStudy=function(scopeCh, mode){
    var ov=document.getElementById('studyOverlay'), fr=document.getElementById('studyFrame');
    var ch=(typeof scopeCh==='number')?scopeCh:null;
    var smode=mode||'quiz';
    function sync(){ try{ if(fr.contentWindow){ var msg={type:'sync',dark:isDark(),mode:smode}; if(ch!=null) msg.ch=ch; fr.contentWindow.postMessage(msg,'*'); } }catch(e){} }
    if(!loaded){
      var b=document.getElementById('studyB64').textContent.trim();
      var by=Uint8Array.from(atob(b), function(c){return c.charCodeAt(0);});
      var html=new TextDecoder('utf-8').decode(by);
      fr.src=URL.createObjectURL(new Blob([html],{type:'text/html'}));
      loaded=true; fr.addEventListener('load', function(){ setTimeout(sync,60); }, {once:true});
    } else { sync(); }
    ov.classList.add('on'); ov.setAttribute('aria-hidden','false');
  };
  window.openEssay=function(){ window.openStudy(null,'essay'); };
  window.closeStudy=function(){
    var ov=document.getElementById('studyOverlay');
    ov.classList.remove('on'); ov.setAttribute('aria-hidden','true');
  };
  document.addEventListener('keydown',function(e){ if(e.key==='Escape'){ var ov=document.getElementById('studyOverlay'); if(ov&&ov.classList.contains('on')) closeStudy(); }});
})();
</script>
<script>window.__lotfNoGate=false;</script>
<script>
/* ===== FLOW CONTROLLER v2: 읽기전 → (어휘 → 본문 → [점검 관문] → 분석) → 다음 장 어휘 ===== */
(function(){
  var PKEY='lotf_flow_passed';   /* {ch:true} = 그 장 점검 통과 */
  var MKEY='lotf_flow_maxidx';   /* 가장 멀리 열린 위치(정수). 0=읽기전 */
  var VKEY='lotf_flow_vocabdone';/* {ch:true} = 그 장 어휘 40개 이상 학습 → 본문 해금 */
  var SKEY='lotf_flow_selfok';   /* {ch:true} = 그 장 분석 '선생님 피드백' 클릭 → 다음 장 어휘 해금 */
  var STAGES=['vocab','read','analyze'];
  var NCH=12;
  function load(k){try{return JSON.parse(localStorage.getItem(k));}catch(e){return null;}}
  function save(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}
  var passed=load(PKEY)||{};
  var vdone=load(VKEY)||{};
  var selfok=load(SKEY)||{};
  var maxIdx=load(MKEY); if(typeof maxIdx!=='number'||isNaN(maxIdx)) maxIdx=0;
  var curPos=0; /* 현재 시퀀스 위치(0=읽기전). chsel이 흔들려도 이전/다음이 견고하도록 별도 추적 */
  var driving=false; /* goTo가 chsel을 조작하는 동안 드롭다운 점프 핸들러 중복 방지 */
  function setDriving(v){ driving=v; try{ window.__lotfDriving=v; }catch(e){} }
  function saveP(){save(PKEY,passed);}
  function saveM(){save(MKEY,maxIdx);}
  function saveV(){save(VKEY,vdone);}
  function saveS(){save(SKEY,selfok);}
  function noGate(){return !!window.__lotfNoGate;}

  /* ---- 위치 인덱싱: 0=읽기전, 그 외 (ch-1)*3 + stageIdx + 1 ---- */
  function posIdx(ch,stage){ if(!ch||ch<1) return 0; return (ch-1)*3 + STAGES.indexOf(stage) + 1; }
  function idxPos(idx){ if(idx<=0) return {ch:0,stage:'intro'}; var k=idx-1; return {ch:Math.floor(k/3)+1, stage:STAGES[k%3]}; }

  function chNum(){ return window.__lotfChap?window.__lotfChap():null; }
  function selIdx(){ var s=document.getElementById('chsel'); var v=s?s.value:''; return (v==='intro'||v==='')?0:parseInt(v,10); }
  function selectChapterOption(ch){ var s=document.getElementById('chsel'); if(!s)return false;
    for(var o=0;o<s.options.length;o++){ if(new RegExp('^\\s*'+ch+'[^0-9]').test(s.options[o].textContent||'')){ s.value=s.options[o].value; return true; } } return false; }

  /* ---- 잠금 규칙 ---- */
  function chUnlocked(ch){ if(noGate())return true; if(!ch)return true; return ch<=1 || (!!passed[ch-1] && !!selfok[ch-1]); }
  function locks(ch){ if(noGate())return {vocab:1,read:1,analyze:1}; var u=chUnlocked(ch); return {vocab:u, read: u && !!vdone[ch], analyze: u && !!passed[ch]}; }

  function flash(msg){ var t=document.getElementById('fnToast'); if(!t){t=document.createElement('div');t.id='fnToast';document.body.appendChild(t);} t.textContent=msg; t.className='show'; clearTimeout(t._t); t._t=setTimeout(function(){t.className='';},2400); }
  function bumpMax(idx){ if(idx>maxIdx){ maxIdx=idx; saveM(); } }
  function isDark(){ return document.documentElement.classList.contains('dark'); }

  function detectStage(){
    var so=document.getElementById('studyOverlay'); if(so&&so.classList.contains('on'))return 'quiz';
    var vo=document.getElementById('vocabOverlay'); if(vo&&vo.classList.contains('on'))return 'vocab';
    if(document.body.classList.contains('mode-analyze'))return 'analyze';
    return 'read';
  }

  function openQuiz(ch){ if(!ch) ch=chNum(); try{closeVocab();}catch(e){} if(typeof openStudy==='function') openStudy(ch); }

  /* ---- 특정 (장, 단계)로 이동 ---- */
  function goTo(ch, stage){
    if(stage==='intro' || !ch){
      var s0=document.getElementById('chsel'); if(s0){ setDriving(true); s0.value='intro'; s0.dispatchEvent(new Event('change')); setDriving(false); }
      try{closeStudy();}catch(e){} try{closeVocab();}catch(e){}
      curPos=0;
      window.scrollTo(0,0); setTimeout(renderNavs,30); return;
    }
    var L=locks(ch);
    if(stage==='analyze' && !L.analyze){ flash(ch+'장 점검을 통과하면 분석이 열려요.'); openQuiz(ch); return; }
    if((stage==='vocab'||stage==='read') && !L.vocab){ flash(ch+'장은 아직 잠겨 있어요. 이전 장 점검 통과 + 선생님 피드백을 먼저 마치세요.'); return; }
    if(stage==='read' && !L.read){ flash(ch+'장 어휘를 40개 이상 학습해야 본문이 열려요. 어휘 탭으로 이동합니다.'); stage='vocab'; }
    if(chNum()!==ch){ if(selectChapterOption(ch)){ var s=document.getElementById('chsel'); setDriving(true); s.dispatchEvent(new Event('change')); setDriving(false); } }
    var idx=selIdx();
    if(stage==='vocab'){ try{closeStudy();}catch(e){} if(typeof openVocab==='function') openVocab();
      var vf=document.getElementById('vocabFrame');
      (function(targetCh){ var tries=0; (function tick(){ var done=false; try{ if(vf&&vf.contentWindow){ vf.contentWindow.postMessage({type:'lotf-vocab-load',ch:targetCh},'*'); } }catch(e){} try{ if(vf&&vf.contentWindow&&typeof vf.contentWindow.loadChapter==='function'){ vf.contentWindow.loadChapter(targetCh); done=true; } }catch(e){} if(tries++<8) setTimeout(tick,80); })(); })(ch);
    } else if(stage==='read'){ try{closeStudy();}catch(e){} try{closeVocab();}catch(e){} if(typeof enterRead==='function') enterRead(idx); }
    else if(stage==='analyze'){ try{closeStudy();}catch(e){} try{closeVocab();}catch(e){} if(typeof enterAnalyze==='function') enterAnalyze(idx); }
    bumpMax(posIdx(ch,stage));
    curPos=posIdx(ch,stage);
    window.scrollTo(0,0);
    setTimeout(renderNavs,30);
  }
  window.__lotfGoTo=goTo;
  window.__lotfOpenQuiz=openQuiz;

  /* ---- 탭(어휘/본문/분석) 클릭 ---- */
  function navTo(to){ var ch=chNum(); if(!ch){ ch=idxPos(curPos).ch||0; } if(!ch){ flash('먼저 장을 선택하세요.'); return; } goTo(ch,to); }
  window.__lotfNav=navTo;

  /* ---- 하단 이전/다음: 한 줄 시퀀스 ---- */
  function curIdxNow(){ var s=detectStage(); var ch=chNum();
    if(ch){ var p=(s==='quiz')?posIdx(ch,'read'):posIdx(ch,s); curPos=p; return p; }
    return curPos; }
  function goNext(){
    var cur=curIdxNow(); var from=idxPos(cur); var nx=cur+1; var p=idxPos(nx);
    if(p.ch>NCH){ flash('마지막 단계예요 🎉'); return; }
    if(from.stage==='read' && p.stage==='analyze' && from.ch===p.ch && !locks(p.ch).analyze){
      flash(p.ch+'장 점검을 통과하면 분석이 열려요.'); openQuiz(p.ch); return; }
    if(p.stage==='read' && from.ch===p.ch && !locks(p.ch).read){
      flash(p.ch+'장 어휘를 40개 이상 학습해야 본문이 열려요.'); return; }
    if(p.stage==='vocab' && from.stage==='analyze' && !chUnlocked(p.ch)){
      flash(from.ch+"장 분석에서 '내가 고른 문장으로 분석 점검받기 — 선생님 피드백'을 눌러야 다음 장 어휘가 열려요."); return; }
    if(!locks(p.ch)[p.stage]){ flash('아직 열리지 않은 단계예요.'); return; }
    goTo(p.ch,p.stage);
  }
  function goPrev(){
    var cur=curIdxNow(); var pv=cur-1; if(pv<0)pv=0; var p=idxPos(pv);
    goTo(p.ch||0, p.ch?p.stage:'intro');
  }
  window.__lotfNext=goNext; window.__lotfPrev=goPrev;

  /* ---- 탭바 렌더링: 어휘 / 본문 / 분석 ---- */
  function renderNavs(){
    var ch=chNum(), L=locks(ch||1), cur=detectStage();
    function b(to,label){ var ok=L[to]; var on=(cur===to); return '<button class="fnbtn'+(on?' cur':'')+(ok?'':' lock')+'" data-to="'+to+'"'+(ok?'':' disabled')+'>'+label+(ok?'':' 🔒')+'</button>'; }
    var html=b('vocab','어휘')+b('read','본문')+b('analyze','분석');
    ['fnavRead','fnavVocab','fnavWrite','fnavQuiz','fnavAnalyze'].forEach(function(id){ var el=document.getElementById(id); if(!el)return;
      el.innerHTML=html; el.querySelectorAll('.fnbtn').forEach(function(btn){ btn.onclick=function(){ navTo(btn.dataset.to); }; }); });
  }
  window.__lotfRenderNavs=renderNavs;

  /* ---- 본문 하단 버튼: 'N장 점검'만 남기고 '분석하기'는 숨김 ---- */
  function relabelBottom(){
    var ch=chNum();
    var qb=document.getElementById('chapQuizBtn');
    if(qb && ch){ qb.textContent='📋 '+ch+'장 점검'; qb.onclick=function(){ openQuiz(ch); }; }
    var ab=document.getElementById('toAnalyzeBtn'); if(ab){ ab.style.display='none'; }
    var box=document.getElementById('toAnalyze');
    if(box){ var p=box.querySelector('p'); if(p) p.textContent='본문을 다 읽었으면 점검을 풀어 보세요. 모두 맞히면 분석이 열립니다.'; }
  }
  window.__lotfRelabelBottom=relabelBottom;

  /* ---- 챕터 드롭다운: 잠금 차단 + "가장 멀리 열린 단계"로 점프 ---- */
  function furthestStage(ch){
    if(noGate()) return 'read';
    if(maxIdx>=posIdx(ch,'analyze') && locks(ch).analyze) return 'analyze';
    if(maxIdx>=posIdx(ch,'read') && locks(ch).read) return 'read';
    return 'vocab';
  }
  var sel=document.getElementById('chsel');
  if(sel){ var lastVal=sel.value;
    sel.addEventListener('change',function(ev){
      if(driving){ lastVal=sel.value; return; }
      var v=sel.value; if(v==='intro'){ lastVal=v; return; }
      var opt=sel.options[sel.selectedIndex], mm=(opt&&opt.textContent||'').match(/^\s*(\d+)/), ch=mm?parseInt(mm[1],10):null;
      if(!noGate() && ch && !chUnlocked(ch)){ ev.stopImmediatePropagation(); flash(ch+'장은 아직 잠겨 있어요. 이전 장 점검 통과 + 선생님 피드백을 먼저 마치세요.'); sel.value=lastVal; return; }
      lastVal=v;
    }, true);
    sel.addEventListener('change',function(){
      if(driving) return;
      var v=sel.value; if(v==='intro'){ setTimeout(renderNavs,60); return; }
      var opt=sel.options[sel.selectedIndex], mm=(opt&&opt.textContent||'').match(/^\s*(\d+)/), ch=mm?parseInt(mm[1],10):null;
      if(ch){ var st=furthestStage(ch);
        setTimeout(function(){ relabelBottom(); if(st==='analyze'){ goTo(ch,'analyze'); } else if(st==='vocab'){ goTo(ch,'vocab'); } else { renderNavs(); } },70); }
    });
  }

  /* ---- enterAnalyze 보강: 게이트 + nextRead 라벨(다음 장 어휘) ---- */
  if(typeof window.enterAnalyze==='function'){ var _ea=window.enterAnalyze;
    window.enterAnalyze=function(i){ var ch=chNum();
      if(!noGate() && ch && !locks(ch).analyze){ flash(ch+'장 점검을 통과하면 분석이 열려요.'); openQuiz(ch); return; }
      _ea(i); bumpMax(posIdx(ch,'analyze'));
      var lb=document.getElementById('nextReadLabel'); if(lb){ lb.textContent='다음'; }
      setTimeout(renderNavs,30); }; }
  if(typeof window.enterRead==='function'){ var _er=window.enterRead;
    window.enterRead=function(i){ var ch=chNum();
      if(!noGate() && ch && !locks(ch).read){ flash(ch+'장 어휘를 40개 이상 학습해야 본문이 열려요.'); goTo(ch,'vocab'); return; }
      _er(i); if(ch) bumpMax(posIdx(ch,'read')); setTimeout(function(){relabelBottom();renderNavs();},30); }; }

  /* ---- 분석 화면의 '다음 장' → 다음 장 어휘 / 'back' → 본문 ---- */
  var nb=document.getElementById('nextRead');
  if(nb){ var clone=nb.cloneNode(true); nb.parentNode.replaceChild(clone,nb);
    clone.addEventListener('click',function(){ goNext(); }); }
  var br=document.getElementById('backRead');
  if(br){ var bc=br.cloneNode(true); br.parentNode.replaceChild(bc,br);
    bc.addEventListener('click',function(){ goPrev(); }); }

  /* ---- 하단 이전/다음 버튼 ---- */
  var pv=document.getElementById('prev');
  if(pv){ var pc=pv.cloneNode(true); pc.textContent='← 이전'; pv.parentNode.replaceChild(pc,pv); pc.addEventListener('click',function(){ goPrev(); }); }
  var nx=document.getElementById('next');
  if(nx){ var nc=nx.cloneNode(true); nc.textContent='다음 →'; nx.parentNode.replaceChild(nc,nx); nc.addEventListener('click',function(){ goNext(); }); }

  /* ---- 점검(study) 통과 신호 수신 → 분석 열고 이동 ---- */
  window.addEventListener('message',function(e){ var m=e.data; if(!m)return;
    if(m.type==='lotf-vocab-progress'){
      var need=Math.min(40, m.total||40);
      if(m.ch && m.n>=need && !vdone[m.ch]){ vdone[m.ch]=true; saveV(); flash(m.ch+'장 어휘 '+need+'개 학습 완료! 본문이 열렸어요 📖'); renderNavs(); }
      return;
    }
    if(m.type==='lotf-vocab-complete'){
      if(m.ch){ if(!vdone[m.ch]){ vdone[m.ch]=true; saveV(); } try{closeStudy();}catch(e6){} setTimeout(function(){ goTo(m.ch,'read'); },80); }
      return;
    }
    if(m.type==='lotf-selfcheck'){
      if(m.ch && !selfok[m.ch]){ selfok[m.ch]=true; saveS();
        if(m.ch<NCH) flash(m.ch+'장 선생님 피드백 완료! 다음 장 어휘가 열렸어요 ✨');
        else flash('12장 선생님 피드백 완료! 모든 여정을 마쳤어요 🎉');
        renderNavs(); }
      return;
    }
    if(m.type==='lotf-pass'){
      if(m.passed && !passed[m.ch]){ passed[m.ch]=true; saveP(); bumpMax(posIdx(m.ch,'analyze')); flash(m.ch+'장 점검 통과! 분석이 열렸어요 — 아래 버튼으로 넘어가세요 ✨'); }
      renderNavs(); return;
    }
    if(m.type==='lotf-goanalyze'){ if(m.ch){ try{closeStudy();}catch(e2){} setTimeout(function(){ goTo(m.ch,'analyze'); },80); } return; }
    if(m.type==='lotf-home'){ try{closeStudy();}catch(e3){} try{closeVocab();}catch(e4){} goTo(0,'intro'); return; }
  });

  /* ---- 오버레이가 다른 경로로 열릴 때 탭 상태 갱신 ---- */
  if(window.openStudy){ var _os=window.openStudy; window.openStudy=function(c,mode){ _os(c,mode); setTimeout(renderNavs,30); }; }
  if(window.openVocab){ var _ov=window.openVocab; window.openVocab=function(){ _ov(); setTimeout(renderNavs,30); }; }

  setTimeout(function(){ relabelBottom(); renderNavs(); },250);
})();
</script>

