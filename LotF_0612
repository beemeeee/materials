  const prev = idx>0 ? P[idx-1] : '';
  const next = idx<P.length-1 ? P[idx+1] : '';
  const target = P[idx];
  const user = (prev?('[앞 문맥]\n'+prev+'\n\n'):'')+'[번역할 부분]\n'+target+(next?('\n\n[뒷 문맥]\n'+next):'');
