/* free, keyless translation fallback (works in a downloaded file with internet) */
async function mmTranslate(text){
  const url = 'https://api.mymemory.translated.net/get?q='+encodeURIComponent(text)+'&langpair=en|ko';
  const r = await fetch(url);
  const d = await r.json();
  let t = (d && d.responseData && d.responseData.translatedText) ? d.responseData.translatedText : '';
  if(/MYMEMORY WARNING|QUERY LENGTH LIMIT|INVALID/i.test(t)) t='';
  return t.trim();
}
async function mmTranslateLong(text){
  if(text.length <= 480) return await mmTranslate(text);
  const parts=[]; let buf='';
  text.split(/(?<=[.!?"”])\s+/).forEach(s=>{
    if((buf+' '+s).length > 480){ if(buf) parts.push(buf); buf=s; }
    else buf = buf ? buf+' '+s : s;
  });
  if(buf) parts.push(buf);
  const out=[];
  for(const p of parts){ out.push(await mmTranslate(p)); }
  return out.join(' ');
}

/* try Claude (only authenticated inside Claude.ai); returns def object or null */
async function fetchDefClaude(word, ctx){
  if(claudeAvailable === false) return null;
  try{
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:1000,
        system:'You are a Korean-English dictionary for an ESL student reading the novel "Lord of the Flies". Given an English word and the sentence it appears in, reply with ONLY a JSON object — no markdown, no code fences, no commentary. Fields: "word" = the Korean meaning of the word itself as used here, formatted "뜻 (품사)"; "phrase" = if in THIS sentence the word is part of a phrasal verb or idiom, the exact English phrase as it appears (e.g. "carried on", "give up", "made for"), otherwise null; "phrase_meaning" = the natural Korean meaning of that phrase as used here, otherwise null. Only set phrase/phrase_meaning when it is genuinely an idiom or phrasal verb, not for ordinary word combinations. Keep all Korean concise.',
        messages:[{role:'user', content:'word: "'+word+'"\nsentence: "'+ctx+'"'}]
      })
    });
    if(!res.ok) throw new Error('http '+res.status);
    const data = await res.json();
    let text = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('').trim();
    if(!text) throw new Error('empty');
    text = text.replace(/```json/gi,'').replace(/```/g,'').trim();
    let def;
    try{ def = JSON.parse(text); }
    catch(e){ def = { word: text.replace(/^["'""]|["'""]$/g,'').trim(), phrase:null, phrase_meaning:null }; }
    if(!def || typeof def!=='object' || !def.word) throw new Error('bad');
    claudeAvailable = true;
    return def;
  }catch(e){ if(claudeAvailable!==true) claudeAvailable=false; return null; }
}

async function fetchDef(word, ctx, el){
  let def = await fetchDefClaude(word, ctx);
  let src = 'AI 사전';
  if(!def){
    // fallback for downloaded file: free keyless translator
    try{ const t = await mmTranslate(word); if(t) def = { word:t, phrase:null, phrase_meaning:null }; }catch(e){}
    src = '번역 사전';
  }
  if(!def) def = { word:'(뜻을 가져오지 못했어요 — 인터넷 확인)', phrase:null, phrase_meaning:null };
  apiCache[word.toLowerCase()] = def;
  if(curWord===word && tip.classList.contains('show')){
    curDef = def;
    const dd = document.getElementById('tipdef');
    if(dd) dd.innerHTML = defToHtml(def);
    const sr = document.getElementById('tipsrc');
    if(sr) sr.textContent = src;
    placeTip(el);
  }
}

