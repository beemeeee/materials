      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ model:'claude-sonnet-4-20250514', max_tokens:1000,
        system:'You translate William Golding\'s "Lord of the Flies" into natural, fluent Korean for an ESL student. The previous and next paragraphs are given only as CONTEXT. Translate ONLY the text under [번역할 부분], using the context to fit pronouns, tense and tone to the flow. Reply with ONLY the Korean translation of [번역할 부분] — no English, no labels, no quotation marks, no commentary.',
        messages:[{role:'user', content:user}] })
    });
