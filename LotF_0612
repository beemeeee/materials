/* ---------- glossary lookup with light stemming ---------- */
function glossLookup(raw){
  const w = raw.toLowerCase();
  if(GLOSS[w]) return GLOSS[w];
  const cands = [];
  if(w.endsWith("'s")) cands.push(w.slice(0,-2));
  if(w.endsWith("s'")) cands.push(w.slice(0,-2));
  if(w.endsWith('ied')) cands.push(w.slice(0,-3)+'y');
  if(w.endsWith('ies')) cands.push(w.slice(0,-3)+'y');
  if(w.endsWith('es')) cands.push(w.slice(0,-2));
  if(w.endsWith('s')) cands.push(w.slice(0,-1));
  if(w.endsWith('ing')){ const b=w.slice(0,-3); cands.push(b); cands.push(b+'e');
    if(b.length>=2 && b[b.length-1]===b[b.length-2]) cands.push(b.slice(0,-1)); }
  if(w.endsWith('ed')){ const b=w.slice(0,-2); cands.push(b); cands.push(w.slice(0,-1));
    if(b.length>=2 && b[b.length-1]===b[b.length-2]) cands.push(b.slice(0,-1)); }
  if(w.endsWith('d')) cands.push(w.slice(0,-1));
  if(w.endsWith('ily')) cands.push(w.slice(0,-3)+'y');
  if(w.endsWith('ly')){ cands.push(w.slice(0,-2)); cands.push(w.slice(0,-1)); }
  if(w.endsWith('er')){ cands.push(w.slice(0,-2)); cands.push(w.slice(0,-1)); }
  if(w.endsWith('est')){ cands.push(w.slice(0,-3)); cands.push(w.slice(0,-2)); }
  // -ally / -ably / -ibly adverbs (e.g. frantically, inevitably, horribly)
  if(w.endsWith('ally')){ cands.push(w.slice(0,-4)); cands.push(w.slice(0,-4)+'al'); }
  if(w.endsWith('ably')){ cands.push(w.slice(0,-4)+'able'); }
  if(w.endsWith('ibly')){ cands.push(w.slice(0,-4)+'ible'); }
  // -ves plural -> -f / -fe (e.g. calves, lives)
  if(w.endsWith('ves')){ cands.push(w.slice(0,-3)+'f'); cands.push(w.slice(0,-3)+'fe'); }
  // -ness nouns -> base (guarded so base length >= 4; e.g. baldness, openness, silliness)
  if(w.endsWith('ness') && w.length>=8){ const b=w.slice(0,-4); cands.push(b); if(b.endsWith('i')) cands.push(b.slice(0,-1)+'y'); }
  for(const c of cands){ if(GLOSS[c]) return GLOSS[c]; }
  return null;
}

